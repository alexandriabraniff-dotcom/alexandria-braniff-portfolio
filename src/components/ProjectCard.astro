---
// ProjectCard — renders a single portfolio project entry
interface Props {
  project: {
    id: string;
    name: string;
    blurb: string;
    image: string;
    url: string | null;
    category?: string;
    comingSoon: boolean;
    logos?: string[];
    detail: {
      business: string;
      built: string;
      notable: string;
    } | null;
  };
}

const { project } = Astro.props;
const isLogoProject = project.category === 'logo-brand' && project.logos && project.logos.length > 0;
const modalId = `logo-modal-${project.id}`;
---

<div class="flex flex-col overflow-hidden" style="border: 1px solid #E8E6E0; background: #fff;">
  <!-- Image area: logo grid or single screenshot -->
  {isLogoProject ? (
    <div class="w-full flex-shrink-0 p-4" style="background: #F7F6F2;">
      <div class="grid grid-cols-2 gap-3">
        {project.logos!.map((logo, i) => (
          <div class="flex items-center justify-center p-3" style={i === 3 ? "background: #1B2A4A;" : "background: #fff; border: 1px solid #E8E6E0;"}>
            <img
              src={logo}
              alt={`${project.name} logo variant ${i + 1}`}
              class="w-full object-contain"
              style="max-height: 100px;"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  ) : (
    <div class="w-full flex-shrink-0 p-4" style="background: #fff;">
      <img
        src={project.image}
        alt={`Screenshot of ${project.name}`}
        class="w-full object-contain"
        loading="lazy"
      />
    </div>
  )}

  <!-- Info -->
  <div class="flex flex-col items-center text-center px-8 pt-8 pb-8 flex-1">
    <h3 class="font-display font-bold text-text mb-5" style="font-size: 1.25rem; font-weight: 700;">
      {project.name}
    </h3>
    <p class="font-body text-sm text-muted leading-relaxed mb-8 flex-1">
      {project.detail?.business ?? project.blurb}
    </p>

    {project.comingSoon ? (
      <span class="w-full inline-flex items-center justify-center font-body text-sm font-semibold py-3.5" style="background: #ccc; color: #fff; letter-spacing: 0.02em; cursor: default;">
        Coming Soon
      </span>
    ) : isLogoProject ? (
      <button
        class="logo-modal-trigger w-full inline-flex items-center justify-center font-body text-sm font-semibold py-3.5 transition-colors duration-200"
        style="background: #111; color: #fff; letter-spacing: 0.02em; cursor: pointer;"
        data-modal={modalId}
        onmouseover="this.style.background='#333'"
        onmouseout="this.style.background='#111'"
      >
        Brand Identity
      </button>
    ) : (
      <a
        href={project.url ?? '#'}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full inline-flex items-center justify-center font-body text-sm font-semibold py-3.5 transition-colors duration-200"
        style="background: #111; color: #fff; letter-spacing: 0.02em;"
        onmouseover="this.style.background='#333'"
        onmouseout="this.style.background='#111'"
      >
        View Project
      </a>
    )}
  </div>
</div>

<!-- Logo Modal -->
{isLogoProject && (
  <div
    id={modalId}
    class="logo-modal fixed inset-0 z-50 hidden items-center justify-center p-6"
    style="background: rgba(0,0,0,0.8); backdrop-filter: blur(8px);"
    role="dialog"
    aria-modal="true"
    aria-label={`${project.name} brand identity`}
  >
    <div class="relative bg-white w-full max-w-xl" style="border-radius: 2px;">
      <!-- Close button -->
      <button
        class="logo-modal-close absolute top-3 right-3 z-10 w-9 h-9 flex items-center justify-center hover:bg-gray-100 transition-colors duration-200"
        style="border: 1px solid #E8E6E0; background: #fff;"
        aria-label="Close"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 1L13 13M13 1L1 13" stroke="#111" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

      <!-- Header -->
      <div class="px-8 pt-7 pb-5" style="border-bottom: 1px solid #E8E6E0;">
        <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-1">Brand Identity</p>
        <h2 class="font-display font-bold text-text" style="font-size: 1.2rem;">{project.name}</h2>
      </div>

      <!-- Carousel -->
      <div class="relative px-8 py-8">
        <!-- Slide track -->
        <div class="logo-track overflow-hidden">
          <div class="logo-slides flex transition-transform duration-400 ease-in-out">
            {project.logos!.map((logo, i) => (
              <div
                class="logo-slide flex-shrink-0 w-full flex items-center justify-center p-10"
                style={i === 3 ? "background: #1B2A4A; min-height: 280px;" : "background: #F7F6F2; border: 1px solid #E8E6E0; min-height: 280px;"}
              >
                <img
                  src={logo}
                  alt={`${project.name} logo variant ${i + 1}`}
                  class="object-contain"
                  style="max-height: 220px; max-width: 100%;"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        </div>

        <!-- Arrows -->
        <button class="logo-prev absolute left-2 top-1/2 -translate-y-1/2 w-9 h-9 flex items-center justify-center bg-white hover:bg-gray-100 transition-colors duration-200 z-10" style="border: 1px solid #E8E6E0;" aria-label="Previous logo">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M9 2L4 7l5 5" stroke="#111" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="logo-next absolute right-2 top-1/2 -translate-y-1/2 w-9 h-9 flex items-center justify-center bg-white hover:bg-gray-100 transition-colors duration-200 z-10" style="border: 1px solid #E8E6E0;" aria-label="Next logo">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M5 2l5 5-5 5" stroke="#111" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>

      <!-- Dots -->
      <div class="flex items-center justify-center gap-2 pb-6">
        {project.logos!.map((_, i) => (
          <button class="logo-dot w-2 h-2 rounded-full transition-colors duration-200" style={i === 0 ? "background: #111;" : "background: #D5D3CB;"} data-index={i} aria-label={`Go to logo ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </div>
)}

<script>
  function closeModal(modal: Element) {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.documentElement.style.overflow = '';
  }

  document.querySelectorAll('.logo-modal').forEach(modal => {
    const slides = modal.querySelectorAll('.logo-slide');
    const track = modal.querySelector('.logo-slides') as HTMLElement | null;
    const dots = modal.querySelectorAll('.logo-dot');
    let current = 0;

    function goTo(index: number) {
      current = (index + slides.length) % slides.length;
      if (track) track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        (d as HTMLElement).style.background = i === current ? '#111' : '#D5D3CB';
      });
    }

    modal.querySelector('.logo-prev')?.addEventListener('click', () => goTo(current - 1));
    modal.querySelector('.logo-next')?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    modal.querySelector('.logo-modal-close')?.addEventListener('click', () => closeModal(modal));
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(modal); });
  });

  document.querySelectorAll('.logo-modal-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const modalId = btn.getAttribute('data-modal');
      if (!modalId) return;
      const modal = document.getElementById(modalId);
      if (!modal) return;
      // Reset to first slide
      const track = modal.querySelector('.logo-slides') as HTMLElement | null;
      if (track) track.style.transform = 'translateX(0)';
      modal.querySelectorAll('.logo-dot').forEach((d, i) => {
        (d as HTMLElement).style.background = i === 0 ? '#111' : '#D5D3CB';
      });
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.documentElement.style.overflow = 'hidden';
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    document.querySelectorAll('.logo-modal:not(.hidden)').forEach(modal => closeModal(modal));
  });
</script>
