---
// ProjectCard — renders a single portfolio project entry
// Accepts the full project object from projects.json
interface Props {
  project: {
    id: string;
    name: string;
    blurb: string;
    image: string;
    url: string | null;
    comingSoon: boolean;
    detail: {
      business: string;
      built: string;
      notable: string;
    } | null;
  };
}

const { project } = Astro.props;
---

<div class="flex flex-col overflow-hidden" style="border: 1px solid #E8E6E0; background: #fff;">
  <!-- Image -->
  <div class="w-full flex-shrink-0 p-4" style="background: #fff;">
    <img
      src={project.image}
      alt={`Screenshot of ${project.name}`}
      class="w-full object-contain"
      loading="lazy"
    />
  </div>

  <!-- Info -->
  <div class="flex flex-col items-center text-center px-8 pt-8 pb-8 flex-1">
    <h3 class="font-display font-bold text-text mb-5" style="font-size: 1.25rem; font-weight: 700;">
      {project.name}
    </h3>
    <p class="font-body text-sm text-muted leading-relaxed mb-8 flex-1">
      {project.detail?.business ?? project.blurb}
    </p>

    {project.comingSoon ? (
      <span
        class="w-full inline-flex items-center justify-center font-body text-sm font-semibold py-3.5"
        style="background: #ccc; color: #fff; letter-spacing: 0.02em; cursor: default;"
      >
        Coming Soon
      </span>
    ) : (
      <a
        href={project.url ?? '#'}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full inline-flex items-center justify-center font-body text-sm font-semibold py-3.5 transition-colors duration-200"
        style="background: #111; color: #fff; letter-spacing: 0.02em;"
        onmouseover="this.style.background='#333'"
        onmouseout="this.style.background='#111'"
      >
        View Project
      </a>
    )}
  </div>
</div>
