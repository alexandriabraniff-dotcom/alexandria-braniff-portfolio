---
// Sticky header — always visible, editorial minimal style
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/contact', label: 'Get in touch' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-base border-b border-surface2">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="flex items-center justify-between h-16 lg:h-[4.5rem]">

      <!-- Wordmark -->
      <a
        href="/"
        class="font-display font-bold text-text text-sm tracking-[-0.02em] hover:text-muted transition-colors duration-200"
        aria-label="Alexandria Braniff — Home"
      >
        Alexandria Braniff
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-10" aria-label="Main navigation">
        {navLinks.map((link) => {
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          const isCTA = link.label === 'Get in touch';
          return isCTA ? (
            <a
              href={link.href}
              class:list={[
                'nav-link font-body text-[11px] font-semibold tracking-[0.12em] uppercase relative py-1 transition-colors duration-200',
                isActive ? 'text-text active-link' : 'text-text hover:text-muted',
              ]}
            >
              {link.label}
            </a>
          ) : (
            <a
              href={link.href}
              class:list={[
                'nav-link font-body text-[11px] font-medium tracking-[0.08em] uppercase relative py-1 transition-colors duration-200',
                isActive ? 'text-text active-link' : 'text-muted hover:text-text',
              ]}
            >
              {link.label}
            </a>
          );
        })}
      </nav>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="w-9 h-9 flex items-center justify-center text-muted hover:text-text transition-colors duration-200 flex-shrink-0"
      >
        <!-- Moon — shown in light mode -->
        <svg id="icon-moon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M13.5 9.5A5.5 5.5 0 0 1 6.5 2.5a5.5 5.5 0 1 0 7 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <!-- Sun — shown in dark mode -->
        <svg id="icon-sun" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="display:none;">
          <circle cx="8" cy="8" r="2.75" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.4 3.4l1.07 1.07M11.53 11.53l1.07 1.07M3.4 12.6l1.07-1.07M11.53 4.47l1.07-1.07" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

      <!-- Mobile hamburger -->
      <button
        id="hamburger-btn"
        class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 focus:outline-none"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="hamburger-line block w-5 h-0.5 bg-text transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-text transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-text transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <div
    id="mobile-nav"
    class="md:hidden overflow-hidden max-h-0 transition-all duration-300 ease-in-out"
    aria-hidden="true"
  >
    <nav
      class="px-6 pb-6 pt-2 flex flex-col gap-1 border-t border-surface2 bg-base"
      aria-label="Mobile navigation"
    >
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        const isCTA = link.label === 'Get in touch';
        return isCTA ? (
          <a
            href={link.href}
            class="font-body text-sm font-semibold tracking-[0.1em] uppercase text-text border-b border-text pb-0.5 mt-2 inline-block hover:text-muted hover:border-muted transition-colors duration-200"
          >
            {link.label}
          </a>
        ) : (
          <a
            href={link.href}
            class:list={[
              'font-body text-base font-medium py-3 border-b border-surface2',
              isActive ? 'text-text' : 'text-muted hover:text-text',
            ]}
          >
            {link.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<!-- Spacer so page content clears the fixed header -->
<div class="h-16 lg:h-[4.5rem]"></div>

<style is:global>
  /* Nav underline hover */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-text);
    transition: width 0.25s ease-out;
  }
  .nav-link:hover::after { width: 100%; }
  .nav-link.active-link::after { width: 100%; }

  /* Hamburger → X */
  #site-header.menu-open .hamburger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #site-header.menu-open .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #site-header.menu-open .hamburger-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  // Theme toggle
  const themeBtn = document.getElementById('theme-toggle');
  const iconMoon = document.getElementById('icon-moon');
  const iconSun = document.getElementById('icon-sun');

  function applyTheme(dark: boolean) {
    document.documentElement.classList.toggle('dark', dark);
    if (iconMoon) iconMoon.style.display = dark ? 'none' : '';
    if (iconSun)  iconSun.style.display  = dark ? '' : 'none';
    localStorage.setItem('theme', dark ? 'dark' : 'light');
  }

  // Sync icon to current state on load
  applyTheme(document.documentElement.classList.contains('dark'));

  themeBtn?.addEventListener('click', () => {
    applyTheme(!document.documentElement.classList.contains('dark'));
  });

  const header = document.getElementById('site-header');
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const mobileNav = document.getElementById('mobile-nav');

  let menuOpen = false;

  hamburgerBtn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      header?.classList.add('menu-open');
      mobileNav?.classList.remove('max-h-0');
      mobileNav?.classList.add('max-h-96');
      hamburgerBtn.setAttribute('aria-expanded', 'true');
      mobileNav?.setAttribute('aria-hidden', 'false');
    } else {
      header?.classList.remove('menu-open');
      mobileNav?.classList.remove('max-h-96');
      mobileNav?.classList.add('max-h-0');
      hamburgerBtn.setAttribute('aria-expanded', 'false');
      mobileNav?.setAttribute('aria-hidden', 'true');
    }
  });

  mobileNav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false;
      header?.classList.remove('menu-open');
      mobileNav.classList.remove('max-h-96');
      mobileNav.classList.add('max-h-0');
      hamburgerBtn?.setAttribute('aria-expanded', 'false');
      mobileNav.setAttribute('aria-hidden', 'true');
    });
  });
</script>
