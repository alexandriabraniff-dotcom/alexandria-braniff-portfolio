---
// Sticky header — always visible, editorial minimal style
const currentPath = Astro.url.pathname;

interface Props {
  heroPage?: boolean;
}
const { heroPage = false } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/portfolio', label: 'Projects' },
  { href: '/contact', label: 'Contact' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-base border-b border-surface2"
  data-hero-page={heroPage ? 'true' : undefined}
  style={heroPage ? 'transform: translateY(-100%); opacity: 0; transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94), opacity 0.4s ease;' : undefined}
>
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="flex items-center justify-between h-16 lg:h-[4.5rem]">

      <!-- Logo -->
      <a
        href="/"
        class="flex items-center hover:opacity-80 transition-opacity duration-200"
        aria-label="Alexandria Braniff — Home"
      >
        <img
          src="/images/ab-logo.png"
          alt="Alexandria Braniff"
          class="h-10 w-10 object-contain"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-10" aria-label="Main navigation">
        {navLinks.map((link) => {
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          const isCTA = link.label === 'Get in touch';
          return isCTA ? (
            <a
              href={link.href}
              class:list={[
                'nav-link font-body text-[11px] font-semibold tracking-[0.12em] uppercase relative py-1 transition-colors duration-200',
                isActive ? 'text-text active-link' : 'text-text hover:text-muted',
              ]}
            >
              {link.label}
            </a>
          ) : (
            <a
              href={link.href}
              class:list={[
                'nav-link font-body text-[11px] font-medium tracking-[0.08em] uppercase relative py-1 transition-colors duration-200',
                isActive ? 'text-text active-link' : 'text-muted hover:text-text',
              ]}
            >
              {link.label}
            </a>
          );
        })}
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="hamburger-btn"
        class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 focus:outline-none"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="hamburger-line block w-5 h-0.5 bg-text transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-text transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-text transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <div
    id="mobile-nav"
    class="md:hidden overflow-hidden max-h-0 transition-all duration-300 ease-in-out"
    aria-hidden="true"
  >
    <nav
      class="px-6 pb-6 pt-2 flex flex-col gap-1 border-t border-surface2 bg-base"
      aria-label="Mobile navigation"
    >
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        const isCTA = link.label === 'Get in touch';
        return isCTA ? (
          <a
            href={link.href}
            class="font-body text-sm font-semibold tracking-[0.1em] uppercase text-text border-b border-text pb-0.5 mt-2 inline-block hover:text-muted hover:border-muted transition-colors duration-200"
          >
            {link.label}
          </a>
        ) : (
          <a
            href={link.href}
            class:list={[
              'font-body text-base font-medium py-3 border-b border-surface2',
              isActive ? 'text-text' : 'text-muted hover:text-text',
            ]}
          >
            {link.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<!-- Spacer so page content clears the fixed header (not needed on hero pages) -->
{!heroPage && <div class="h-16 lg:h-[4.5rem]"></div>}

<style is:global>
  /* Nav underline hover */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-text);
    transition: width 0.25s ease-out;
  }
  .nav-link:hover::after { width: 100%; }
  .nav-link.active-link::after { width: 100%; }

  /* Hamburger → X */
  #site-header.menu-open .hamburger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #site-header.menu-open .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #site-header.menu-open .hamburger-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const mobileNav = document.getElementById('mobile-nav');

  let menuOpen = false;

  hamburgerBtn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      header?.classList.add('menu-open');
      mobileNav?.classList.remove('max-h-0');
      mobileNav?.classList.add('max-h-96');
      hamburgerBtn.setAttribute('aria-expanded', 'true');
      mobileNav?.setAttribute('aria-hidden', 'false');
    } else {
      header?.classList.remove('menu-open');
      mobileNav?.classList.remove('max-h-96');
      mobileNav?.classList.add('max-h-0');
      hamburgerBtn.setAttribute('aria-expanded', 'false');
      mobileNav?.setAttribute('aria-hidden', 'true');
    }
  });

  mobileNav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false;
      header?.classList.remove('menu-open');
      mobileNav.classList.remove('max-h-96');
      mobileNav.classList.add('max-h-0');
      hamburgerBtn?.setAttribute('aria-expanded', 'false');
      mobileNav.setAttribute('aria-hidden', 'true');
    });
  });
</script>
