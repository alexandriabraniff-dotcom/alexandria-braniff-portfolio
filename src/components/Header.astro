---
// Sticky header — hidden on homepage until user scrolls past the hero.
// On all other pages it is always visible.
const currentPath = Astro.url.pathname;
const isHomepage = currentPath === '/';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/portfolio', label: 'Portfolio & Services' },
  { href: '/contact', label: 'Get in touch' },
];
---

<header
  id="site-header"
  class:list={['fixed top-0 left-0 right-0 z-50', isHomepage ? 'homepage-nav' : 'always-visible']}
  data-homepage={isHomepage}
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Wordmark -->
      <a
        href="/"
        class="font-display font-bold text-text tracking-tight text-[1.125rem] hover:text-coral transition-colors duration-200 relative z-10"
        aria-label="Alexandria Braniff - Home"
      >
        Alexandria Braniff
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        {navLinks.map((link) => {
          const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
          const isCTA = link.label === 'Get in touch';
          return isCTA ? (
            <a
              href={link.href}
              class="font-body text-sm font-bold bg-coral text-[#0E0E10] px-4 py-2 rounded hover:bg-coral-dark transition-colors duration-200"
            >
              {link.label}
            </a>
          ) : (
            <a
              href={link.href}
              class:list={[
                'nav-link font-body text-sm font-medium relative py-1',
                isActive ? 'text-coral active-link' : 'text-muted hover:text-text',
              ]}
            >
              {link.label}
            </a>
          );
        })}

      </nav>

      <!-- Mobile hamburger -->
      <button
        id="hamburger-btn"
        class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 relative z-10 focus:outline-none"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="hamburger-line block w-6 h-0.5 bg-text transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-text transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-text transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <div
    id="mobile-nav"
    class="md:hidden overflow-hidden max-h-0 transition-all duration-300 ease-in-out"
    aria-hidden="true"
  >
    <nav
      class="px-6 pb-6 pt-2 flex flex-col gap-1 border-t border-surface2"
      aria-label="Mobile navigation"
    >
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        const isCTA = link.label === 'Get in touch';
        return isCTA ? (
          <a
            href={link.href}
            class="font-body text-sm font-bold bg-coral text-[#0E0E10] rounded px-5 py-3 hover:bg-coral-dark transition-colors duration-200 mt-2 inline-block"
          >
            {link.label}
          </a>
        ) : (
          <a
            href={link.href}
            class:list={[
              'font-body text-base font-medium py-3 border-b border-surface2',
              isActive ? 'text-coral' : 'text-muted hover:text-text',
            ]}
          >
            {link.label}
          </a>
        );
      })}

    </nav>
  </div>
</header>

<!-- Spacer: only on non-homepage pages since hero is full viewport on homepage -->
{!isHomepage && <div class="h-16 lg:h-20"></div>}

<style is:global>
  /* Always visible on inner pages */
  #site-header.always-visible {
    background: rgba(14, 14, 16, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid #252529;
  }

  /* Homepage: hidden above viewport, slides down on scroll */
  #site-header.homepage-nav {
    transform: translateY(-100%);
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    background: rgba(14, 14, 16, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #252529;
  }

  #site-header.homepage-nav.revealed {
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Nav link hover: teal underline slides in from left */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1.5px;
    background-color: var(--color-teal);
    transition: width 0.25s ease-out;
  }

  .nav-link:hover::after { width: 100%; }

  .nav-link.active-link::after {
    width: 100%;
    background-color: var(--color-coral);
  }

  /* Hamburger → X */
  #site-header.menu-open .hamburger-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #site-header.menu-open .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #site-header.menu-open .hamburger-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  const header = document.getElementById('site-header') as HTMLElement | null;
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const mobileNav = document.getElementById('mobile-nav');

  // Detect homepage from the URL — no reliance on Astro data attributes
  const isHomepage = window.location.pathname === '/';

  // ── Scroll behaviour ────────────────────────────────────────────────────────
  if (isHomepage && header) {
    function updateHeader() {
      // Measure hero height fresh on each call so it's always accurate
      const hero = document.getElementById('hero');
      const threshold = hero ? hero.offsetHeight - 60 : window.innerHeight - 60;
      if (window.scrollY >= threshold) {
        header!.classList.add('revealed');
      } else {
        header!.classList.remove('revealed');
      }
    }

    window.addEventListener('scroll', updateHeader, { passive: true });
  }

  // ── Hamburger toggle ────────────────────────────────────────────────────────
  let menuOpen = false;

  hamburgerBtn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      header?.classList.add('menu-open');
      mobileNav?.classList.remove('max-h-0');
      mobileNav?.classList.add('max-h-96');
      hamburgerBtn.setAttribute('aria-expanded', 'true');
      mobileNav?.setAttribute('aria-hidden', 'false');
    } else {
      header?.classList.remove('menu-open');
      mobileNav?.classList.remove('max-h-96');
      mobileNav?.classList.add('max-h-0');
      hamburgerBtn.setAttribute('aria-expanded', 'false');
      mobileNav?.setAttribute('aria-hidden', 'true');
    }
  });

  mobileNav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false;
      header?.classList.remove('menu-open');
      mobileNav.classList.remove('max-h-96');
      mobileNav.classList.add('max-h-0');
      hamburgerBtn?.setAttribute('aria-expanded', 'false');
      mobileNav.setAttribute('aria-hidden', 'true');
    });
  });
</script>
