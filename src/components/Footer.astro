---
// Site footer — wordmark, nav links, copyright, contact email
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/portfolio', label: 'Portfolio & Services' },
  { href: '/contact', label: 'Get in touch' },
];
---

<footer class="bg-base border-t border-surface2 mt-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12">

    <!-- Top row: wordmark + nav links -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8 mb-10">

      <!-- Logo -->
      <a
        href="/"
        class="flex flex-col items-start gap-3 hover:opacity-70 transition-opacity duration-200"
        aria-label="Alexandria Braniff - Home"
      >
        <img src="/images/ab-logo.png" alt="Alexandria Braniff" class="h-16 w-16 object-contain" />
        <span class="font-display font-bold text-text text-sm tracking-tight">Alexandria Braniff</span>
      </a>

      <!-- Footer navigation -->
      <nav class="flex flex-wrap gap-x-8 gap-y-3" aria-label="Footer navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-body text-sm text-muted hover:text-text transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Divider -->
    <div class="border-t border-surface2 mb-8"></div>

    <!-- Bottom row: copyright + email -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">

      <!-- Copyright + tagline -->
      <div>
        <p class="font-body text-sm text-muted">
          &copy; 2026 Alexandria Braniff
        </p>
        <p class="font-body text-xs text-muted mt-1 opacity-70">
          Web developer for small businesses. Vancouver, BC.
        </p>
      </div>

    </div>
  </div>
</footer>
