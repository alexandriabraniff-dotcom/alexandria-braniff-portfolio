---
// Homepage — hero, intro, portfolio teaser, services summary, CTA
import Layout from '../layouts/Layout.astro';
import AnimateIn from '../components/AnimateIn.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';

// Show first 3 projects in teaser
const featuredProjects = projects.slice(0, 3);
---

<Layout
  title="Alexandria Braniff — Web Developer for Small Businesses"
  description="Custom websites for small businesses. Designed and built from scratch by Alexandria Braniff, web developer in Vancouver, BC."
>

  <!-- ============================================
       HERO SECTION — Full viewport, editorial
       Nav lives here; sticky header drops in on scroll
  ============================================ -->
  <section id="hero" class="relative min-h-screen flex flex-col overflow-hidden">

    <!-- Atmospheric background glows -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute rounded-full" style="width:500px;height:500px;background:var(--color-coral);opacity:0.07;filter:blur(120px);top:-10%;right:-5%;"></div>
      <div class="absolute rounded-full" style="width:400px;height:400px;background:var(--color-teal);opacity:0.06;filter:blur(140px);bottom:-10%;left:-5%;"></div>
    </div>

    <!-- In-hero navigation -->
    <div class="relative z-20 flex items-center justify-between px-6 lg:px-12 pt-8 lg:pt-10">

      <!-- Wordmark visible on mobile since no sticky header yet -->
      <span
        class="font-display font-bold text-text tracking-tight text-base md:hidden"
        style="animation: fadeUp 0.6s ease-out both; animation-delay: 0ms;"
      >
        Alexandria Braniff
      </span>

      <!-- Desktop nav links -->
      <nav class="hidden md:flex items-center gap-8 ml-auto" aria-label="Hero navigation">
        {[
          { href: '/about', label: 'About' },
          { href: '/portfolio', label: 'Portfolio & Services' },
          { href: '/contact', label: 'Get in touch' },
        ].map((link, i) => (
          link.label === 'Get in touch' ? (
            <a
              href={link.href}
              class="font-body text-sm font-bold bg-coral text-[#0E0E10] px-4 py-2 rounded hover:bg-coral-dark transition-colors duration-200"
              style={`animation: fadeUp 0.6s ease-out both; animation-delay: ${i * 60}ms;`}
            >
              {link.label}
            </a>
          ) : (
            <a
              href={link.href}
              class="hero-nav-link font-body text-sm text-muted hover:text-text transition-colors duration-200 relative py-1"
              style={`animation: fadeUp 0.6s ease-out both; animation-delay: ${i * 60}ms;`}
            >
              {link.label}
            </a>
          )
        ))}
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="hero-mobile-btn"
        class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 focus:outline-none"
        aria-label="Open navigation"
      >
        <span class="block w-6 h-0.5 bg-text"></span>
        <span class="block w-6 h-0.5 bg-text"></span>
        <span class="block w-6 h-0.5 bg-text"></span>
      </button>
    </div>

    <!-- Hero main content — centered on mobile, bottom-anchored on desktop -->
    <div class="relative z-10 flex-1 flex flex-col justify-center lg:justify-end px-6 lg:px-12 pb-0 lg:pb-16 pt-8 lg:pt-0">

      <!-- The name — scales safely across all screen sizes -->
      <h1
        class="font-display font-bold text-text tracking-[-0.03em] mb-4 lg:mb-6"
        style="font-size: clamp(3rem, 10vw, 13rem); line-height: 0.92; animation: fadeUp 0.8s ease-out both; animation-delay: 180ms;"
      >
        Alexandria<br />Braniff
      </h1>

      <!-- Sub-name blurb -->
      <p
        class="font-body text-sm lg:text-base leading-relaxed max-w-sm mb-8"
        style="color: var(--color-muted); animation: fadeUp 0.7s ease-out both; animation-delay: 260ms;"
      >
        Creating functional tech and web designs for small businesses.
      </p>

      <!-- CTA buttons -->
      <div
        class="flex flex-col sm:flex-row gap-3 sm:gap-4"
        style="animation: fadeUp 0.7s ease-out both; animation-delay: 340ms;"
      >
        <a
          href="/portfolio"
          class="flex justify-center font-body font-bold text-sm border border-text text-text rounded px-6 py-3 hover:border-teal hover:text-teal transition-colors duration-200"
        >
          View my work
        </a>
        <a
          href="/contact"
          class="flex justify-center font-body font-bold text-sm bg-coral text-[#0E0E10] rounded px-6 py-3 hover:bg-coral-dark transition-colors duration-200"
        >
          Get in touch
        </a>
      </div>

    </div>

    <!-- Decorative rotating outlines (desktop only) -->
    <div class="hidden lg:block absolute pointer-events-none" aria-hidden="true" style="right:8%;top:20%;width:280px;height:280px;">
      <div class="absolute inset-0 border border-coral/20 rounded-sm" style="animation: slowRotate 24s linear infinite;"></div>
      <div class="absolute inset-8 border border-teal/20 rounded-sm" style="animation: slowRotate 16s linear infinite reverse;"></div>
    </div>

  </section>

  <!-- ============================================
       INTRO SECTION — Who Alexandria is
  ============================================ -->
  <section class="px-6 lg:px-8 py-24 lg:py-32 relative overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">

        <!-- Decorative column with number -->
        <div class="relative" aria-hidden="true">
          <span
            class="font-display font-bold select-none pointer-events-none"
            style="
              font-size: clamp(8rem, 18vw, 16rem);
              color: var(--color-muted);
              opacity: 0.08;
              line-height: 1;
              display: block;
            "
          >
            01
          </span>
        </div>

        <!-- Content column -->
        <AnimateIn>
          <div class="lg:pt-4">
            <h2 class="font-display font-bold text-text mb-8" style="font-size: clamp(1.75rem, 3.5vw, 2.75rem); line-height: 1.15;">
              Small business websites,<br />done properly.
            </h2>

            <div class="space-y-5 font-body text-base text-muted leading-relaxed">
              <p>
                I'm Alexandria - a web developer based in Vancouver, British Columbia. I build custom
                websites for small businesses that want to look like they mean it online. Not a
                template, not a drag-and-drop builder, not a site that looks like everyone else's.
              </p>
              <p>
                Every project starts with a real conversation. I find out what you do, who your
                customers are, and what you actually need the site to achieve. Then I build it from
                scratch, handle the tech, and hand you something you're proud to share.
              </p>
              <p>
                I work with cafes, gyms, tradies, boutiques, and anyone else who needs a proper
                web presence but doesn't want to deal with a big agency or figure it all out
                themselves.
              </p>
            </div>

            <a
              href="/about"
              class="inline-flex items-center gap-2 font-body text-sm font-semibold text-coral hover:text-coral-dark transition-colors duration-200 mt-8"
            >
              <span aria-hidden="true">&#8594;</span>
              About me
            </a>
          </div>
        </AnimateIn>

      </div>
    </div>
  </section>

  <!-- ============================================
       PORTFOLIO TEASER — First 3 projects
  ============================================ -->
  <section class="px-6 lg:px-8 py-24 lg:py-32 border-t border-surface2">
    <div class="max-w-7xl mx-auto">

      <!-- Section header -->
      <AnimateIn>
        <p class="font-body text-xs font-semibold tracking-[0.2em] uppercase text-teal mb-4">
          02 / Selected Work
        </p>
        <h2 class="font-display font-bold text-text mb-16" style="font-size: clamp(1.75rem, 3.5vw, 2.75rem);">
          Recent projects.
        </h2>
      </AnimateIn>

      <!-- Project cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {featuredProjects.map((project, i) => (
          <AnimateIn delay={i * 100}>
            <ProjectCard project={project} />
          </AnimateIn>
        ))}
      </div>

      <!-- View all link -->
      <AnimateIn>
        <a
          href="/portfolio"
          class="inline-flex items-center gap-2 font-body text-sm font-semibold text-coral hover:text-coral-dark transition-colors duration-200"
        >
          View all work
          <span aria-hidden="true">&#8594;</span>
        </a>
      </AnimateIn>

    </div>
  </section>

  <!-- ============================================
       SERVICES SUMMARY — 4 services, 2x2 grid
  ============================================ -->
  <section class="px-6 lg:px-8 py-24 lg:py-32 border-t border-surface2">
    <div class="max-w-7xl mx-auto">

      <!-- Section header -->
      <AnimateIn>
        <p class="font-body text-xs font-semibold tracking-[0.2em] uppercase text-teal mb-4">
          03 / What I Do
        </p>
        <h2 class="font-display font-bold text-text mb-16" style="font-size: clamp(1.75rem, 3.5vw, 2.75rem);">
          Everything your business<br />needs online.
        </h2>
      </AnimateIn>

      <!-- Services 2x2 grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-12">

        <!-- Service 1 -->
        <AnimateIn delay={0}>
          <div>
            <span class="font-display font-bold text-4xl text-teal mb-4 block">01</span>
            <h3 class="font-display font-bold text-xl text-text mb-3">Website Design & Build</h3>
            <p class="font-body text-sm text-muted leading-relaxed">
              A complete custom website, designed and built around your business. From first
              conversation to launch day, I handle everything so you don't have to.
            </p>
          </div>
        </AnimateIn>

        <!-- Service 2 -->
        <AnimateIn delay={100}>
          <div>
            <span class="font-display font-bold text-4xl text-teal mb-4 block">02</span>
            <h3 class="font-display font-bold text-xl text-text mb-3">Custom Development</h3>
            <p class="font-body text-sm text-muted leading-relaxed">
              Need something specific that off-the-shelf tools can't handle? I build custom
              functionality to spec - booking flows, integrations, dynamic content and more.
            </p>
          </div>
        </AnimateIn>

        <!-- Service 3 -->
        <AnimateIn delay={200}>
          <div>
            <span class="font-display font-bold text-4xl text-teal mb-4 block">03</span>
            <h3 class="font-display font-bold text-xl text-text mb-3">Site Maintenance</h3>
            <p class="font-body text-sm text-muted leading-relaxed">
              Websites need care after launch. Monthly maintenance plans keep your site updated,
              secure, and running well. No more chasing someone for a content change.
            </p>
          </div>
        </AnimateIn>

        <!-- Service 4 -->
        <AnimateIn delay={300}>
          <div>
            <span class="font-display font-bold text-4xl text-teal mb-4 block">04</span>
            <h3 class="font-display font-bold text-xl text-text mb-3">Digital Setup & Tech</h3>
            <p class="font-body text-sm text-muted leading-relaxed">
              Domain, hosting, business email, Google Business Profile, analytics. I handle the
              full digital setup so your entire online presence actually works.
            </p>
          </div>
        </AnimateIn>

      </div>

    </div>
  </section>

  <!-- ============================================
       CLOSING CTA — Full-width dark section
  ============================================ -->
  <section class="relative px-6 lg:px-8 py-32 lg:py-40 overflow-hidden border-t border-surface2">

    <!-- Background coral blob -->
    <div
      class="absolute rounded-full pointer-events-none"
      aria-hidden="true"
      style="
        width: 600px;
        height: 600px;
        background: var(--color-coral);
        opacity: 0.06;
        filter: blur(120px);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      "
    ></div>

    <div class="max-w-3xl mx-auto text-center relative z-10">
      <AnimateIn>
        <h2
          class="font-display font-bold text-text mb-6"
          style="font-size: clamp(2.5rem, 6vw, 5rem); line-height: 1.05;"
        >
          Ready to build something?
        </h2>
        <p class="font-body text-muted text-lg mb-10">
          Let's talk about your project.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 font-body font-bold text-sm bg-coral text-[#0E0E10] rounded px-8 py-4 hover:bg-coral-dark transition-colors duration-200"
        >
          Get in touch
          <span aria-hidden="true">&#8594;</span>
        </a>
      </AnimateIn>
    </div>
  </section>

</Layout>

<style>
  /* Decorative outline rotation */
  @keyframes slowRotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Hero nav link hover underline */
  .hero-nav-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 1.5px;
    background: var(--color-teal);
    transition: width 0.25s ease-out;
  }
  .hero-nav-link:hover::after { width: 100%; }
</style>

<script>
  // Mobile hero button: force-reveal the sticky header and open its mobile menu
  const heroBtn = document.getElementById('hero-mobile-btn');
  heroBtn?.addEventListener('click', () => {
    const header = document.getElementById('site-header');
    const hamburgerBtn = document.getElementById('hamburger-btn');
    header?.classList.add('revealed');
    hamburgerBtn?.click();
    // Scroll slightly so the header stays revealed
    window.scrollTo({ top: 1, behavior: 'instant' });
  });
</script>
