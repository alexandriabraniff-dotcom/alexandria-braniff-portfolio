---
// Homepage — dual layout: light "selling flowers" / dark "expensive perfume bottle"
import Layout from '../layouts/Layout.astro';
import AnimateIn from '../components/AnimateIn.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';

// Only show real web design projects on the homepage
const featuredProjects = projects.filter(p => !p.comingSoon && p.category === 'web-design');
---

<Layout
  title="Alexandria Braniff — Web Developer for Small Businesses"
  description="Custom websites for small businesses. Designed and built from scratch by Alexandria Braniff, web developer in Vancouver, BC."
  heroNav={true}
>

<!-- ================================================
     LIGHT LAYOUT — Selling flowers. Delicate, romantic, elegant.
================================================ -->
<div class="light-layout">

  <!-- HERO -->
  <section id="hero" class="relative overflow-hidden border-b border-surface2 min-h-screen flex flex-col">
    <!-- Integrated hero nav bar -->
    <nav class="hero-nav-bar flex items-center justify-between px-8 lg:px-16 flex-shrink-0" style="background: rgba(247,246,242,0.55); backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); padding-top: 1.75rem; padding-bottom: 1.25rem;">
      <a href="/" class="hover:opacity-70 transition-opacity duration-200" aria-label="Alexandria Braniff — Home">
        <img src="/images/ab-logo.png" alt="Alexandria Braniff" class="h-14 w-14 object-contain" />
      </a>
      <div class="hidden md:flex items-center gap-12">
        <a href="/about" class="font-body text-sm font-medium tracking-[0.08em] uppercase text-muted hover:text-text transition-colors duration-200 relative py-1 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-text hover:after:w-full after:transition-all after:duration-200">About</a>
        <a href="/services" class="font-body text-sm font-medium tracking-[0.08em] uppercase text-muted hover:text-text transition-colors duration-200 relative py-1 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-text hover:after:w-full after:transition-all after:duration-200">Services</a>
        <a href="/portfolio" class="font-body text-sm font-medium tracking-[0.08em] uppercase text-muted hover:text-text transition-colors duration-200 relative py-1 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-text hover:after:w-full after:transition-all after:duration-200">Projects</a>
        <a href="/contact" class="font-body text-sm font-semibold tracking-[0.12em] uppercase text-text hover:text-muted transition-colors duration-200">Contact</a>
      </div>
      <div class="flex items-center gap-2">
        <button class="theme-toggle-btn w-11 h-11 flex items-center justify-center text-muted hover:text-text transition-colors duration-200" aria-label="Toggle dark mode">
          <svg class="icon-moon-hero" width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M13.5 9.5A5.5 5.5 0 0 1 6.5 2.5a5.5 5.5 0 1 0 7 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <svg class="icon-sun-hero hidden" width="20" height="20" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="2.75" stroke="currentColor" stroke-width="1.5"/>
            <path d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.4 3.4l1.07 1.07M11.53 11.53l1.07 1.07M3.4 12.6l1.07-1.07M11.53 4.47l1.07-1.07" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <button class="hero-hamburger md:hidden flex flex-col justify-center items-center w-11 h-11 gap-1.5" aria-label="Open menu" aria-expanded="false" aria-controls="hero-mobile-menu">
          <span class="hero-ham-line block w-6 h-0.5 bg-text transition-all duration-300 origin-center"></span>
          <span class="hero-ham-line block w-6 h-0.5 bg-text transition-all duration-300 origin-center"></span>
          <span class="hero-ham-line block w-6 h-0.5 bg-text transition-all duration-300 origin-center"></span>
        </button>
      </div>
    </nav>

    <!-- Hero mobile menu overlay -->
    <div id="hero-mobile-menu" class="fixed inset-0 z-40 bg-base flex-col hidden" aria-hidden="true" role="dialog" aria-label="Navigation menu">
      <div class="flex items-center justify-between px-6 h-16 border-b border-surface2">
        <a href="/" aria-label="Alexandria Braniff — Home">
          <img src="/images/ab-logo.png" alt="Alexandria Braniff" class="h-9 w-9 object-contain" />
        </a>
        <button class="hero-menu-close w-10 h-10 flex items-center justify-center text-muted hover:text-text" aria-label="Close menu">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M1 1L15 15M15 1L1 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
      <nav class="flex flex-col px-6 py-8 gap-1">
        <a href="/about" class="font-body text-base font-medium py-4 border-b border-surface2 text-muted hover:text-text transition-colors">About</a>
        <a href="/services" class="font-body text-base font-medium py-4 border-b border-surface2 text-muted hover:text-text transition-colors">Services</a>
        <a href="/portfolio" class="font-body text-base font-medium py-4 border-b border-surface2 text-muted hover:text-text transition-colors">Projects</a>
        <a href="/contact" class="font-body text-sm font-semibold tracking-[0.1em] uppercase text-text border-b border-text pb-0.5 mt-4 inline-block hover:text-muted hover:border-muted transition-colors">Contact</a>
      </nav>
      <div class="px-6 pt-4 border-t border-surface2 mt-auto">
        <button class="theme-toggle-btn flex items-center gap-3 font-body text-sm text-muted hover:text-text transition-colors py-2" aria-label="Toggle dark mode">
          <span class="icon-moon-hero"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.5 9.5A5.5 5.5 0 0 1 6.5 2.5a5.5 5.5 0 1 0 7 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <span class="icon-sun-hero hidden"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="2.75" stroke="currentColor" stroke-width="1.5"/><path d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.4 3.4l1.07 1.07M11.53 11.53l1.07 1.07M3.4 12.6l1.07-1.07M11.53 4.47l1.07-1.07" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
          <span>Toggle theme</span>
        </button>
      </div>
    </div>

    <!-- Hero body — centered crest layout -->
    <div class="flex-1 flex flex-col items-center justify-center text-center px-6 py-16 lg:py-20 relative">

      <!-- Background image — inverted circuit pattern -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <img src="/images/hero-bg.jpg" alt="" class="w-full h-full object-cover" style="filter: invert(1); opacity: 0.18;" />
      </div>

      <!-- Name -->
      <h1 class="font-serif text-text leading-tight" style="font-size: clamp(2.6rem, 5.5vw, 5.5rem); font-style: italic; font-weight: 300; animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) both 0.3s;">
        Alexandria Braniff
      </h1>

      <!-- Role label -->
      <p class="font-body text-muted text-[10px] tracking-[0.3em] uppercase mt-4 mb-10 lg:mb-12" style="animation: fadeUp 0.7s ease-out both 0.45s;">
        Web Developer &mdash; Vancouver, BC
      </p>

      <!-- Tagline -->
      <p class="font-body text-sm text-muted leading-relaxed max-w-[340px] mb-10 lg:mb-12" style="animation: fadeUp 0.7s ease-out both 0.55s;">
        Web design and services that keep growing with your business over time.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-3" style="animation: fadeUp 0.7s ease-out both 0.65s;">
        <a href="/portfolio" class="flex justify-center font-body text-sm text-text border border-surface2 px-7 py-3 hover:border-text transition-colors duration-200">View all work</a>
        <a href="/contact" class="flex justify-center font-body text-sm bg-text px-7 py-3 hover:bg-muted transition-colors duration-200" style="color: #F7F6F2; font-weight: 500;">Get in touch</a>
      </div>
    </div>
  </section>

  <!-- INTRO — restructured 2-column with large portrait -->
  <section class="px-6 lg:px-12 py-20 lg:py-28 border-b border-surface2">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-[1fr_400px] gap-12 lg:gap-16 items-stretch">

        <!-- Text column -->
        <div class="flex flex-col justify-center gap-8 py-4">
          <AnimateIn>
            <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-4">About</p>
            <h2 class="font-serif text-text" style="font-size: clamp(1.6rem, 3vw, 2.4rem); line-height: 1.2; font-style: italic; font-weight: 300;">Alexandria Braniff Web Design</h2>
          </AnimateIn>
          <AnimateIn delay={100}>
            <div class="space-y-4 font-body text-sm text-muted leading-relaxed max-w-md">
              <p>Hey, I'm Alexandria. I specialize in creating custom web designs with zero templates — every website is tailored specifically to the client. Before launching into a project, I start with a real conversation to understand your business, your audience, and your goals. I make sure to keep you involved and updated every single step of the way.</p>
              <p>I love collaborating with passionate people who want to grow their companies, those who are nitpicky about the subtle details and excited to learn something new.</p>
              <a href="/about" class="inline-flex items-center gap-2 font-body text-xs font-semibold tracking-[0.15em] uppercase text-text border-b border-text pb-0.5 mt-2 hover:text-muted hover:border-muted transition-colors duration-200">About me &#8594;</a>
            </div>
          </AnimateIn>
        </div>

        <!-- Portrait column — large, prominent -->
        <AnimateIn delay={150}>
          <div class="placeholder-img warm lg:min-h-[520px] min-h-[300px]">
            <img src="/images/alexandria-braniff.jpg" alt="Alexandria Braniff" class="absolute inset-0 w-full h-full object-cover object-top" loading="lazy" />
          </div>
        </AnimateIn>

      </div>
    </div>
  </section>

  <!-- SELECTED WORK -->
  <section class="py-16 lg:py-24 border-b border-surface2">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <AnimateIn>
        <div class="flex items-end justify-between mb-12">
          <div>
            <h2 class="font-serif text-text" style="font-size: clamp(1.8rem, 3.5vw, 3rem); font-style: italic; font-weight: 300;">Projects</h2>
          </div>
          <a href="/portfolio" class="hidden sm:inline-flex items-center gap-2 font-body text-[11px] tracking-[0.12em] uppercase text-muted hover:text-text transition-colors duration-200 border-b border-surface2 hover:border-text pb-0.5">
            View all &#8594;
          </a>
        </div>
      </AnimateIn>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredProjects.map((project, i) => (
          <AnimateIn delay={i * 100}>
            <div class="flex flex-col overflow-hidden" style="border: 1px solid #E8E6E0; background: #fff;">
              <!-- Image -->
              <div class="w-full flex-shrink-0 p-4" style="background: #fff;">
                <img
                  src={project.image}
                  alt={`Screenshot of ${project.name}`}
                  class="w-full object-contain"
                  loading="lazy"
                />
              </div>
              <!-- Info -->
              <div class="flex flex-col items-center text-center px-8 pt-8 pb-8 flex-1">
                <h3 class="font-display font-bold text-text mb-5" style="font-size: 1.25rem; font-weight: 700;">{project.name}</h3>
                <p class="font-body text-sm text-muted leading-relaxed mb-8 flex-1">{project.detail?.business ?? project.blurb}</p>
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-full inline-flex items-center justify-center font-body text-sm font-semibold py-3.5 transition-colors duration-200"
                  style="background: #111; color: #fff; letter-spacing: 0.02em;"
                  onmouseover="this.style.background='#333'"
                  onmouseout="this.style.background='#111'"
                >
                  View Project
                </a>
              </div>
            </div>
          </AnimateIn>
        ))}
      </div>

      <AnimateIn>
        <div class="mt-10 sm:hidden">
          <a href="/portfolio" class="inline-flex items-center gap-2 font-body text-sm font-medium text-text hover:text-muted transition-colors duration-200">
            <span class="h-px w-6 bg-text inline-block"></span>View all work
          </a>
        </div>
      </AnimateIn>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="px-6 lg:px-12 py-16 lg:py-24 border-b border-surface2">
    <div class="max-w-7xl mx-auto">
      <AnimateIn>
        <div class="mb-12">
          <h2 class="font-serif text-text" style="font-size: clamp(1.8rem, 3.5vw, 3rem); font-style: italic; font-weight: 300;">Our Services</h2>
        </div>
      </AnimateIn>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          {
            title: 'Website Design & Build',
            body: 'A complete custom website designed and built around your business. From first conversation to launch day, I handle everything.',
            icon: '01',
          },
          {
            title: 'Custom Development',
            body: "Need something specific? I build custom functionality to spec — booking flows, integrations, and more.",
            icon: '02',
          },
          {
            title: 'Site Maintenance',
            body: 'Monthly plans keep your site updated, secure, and running well. No more chasing someone for a simple content change.',
            icon: '03',
          },
          {
            title: 'Digital Setup & Tech',
            body: 'Domain, hosting, business email, Google Business Profile, analytics. I handle the full digital setup.',
            icon: '04',
          },
        ].map((svc, i) => (
          <AnimateIn delay={i * 80}>
            <a href="/services" class="svc-card group block border border-surface2 p-7 hover:border-text transition-colors duration-200">
              <h3 class="font-serif text-text mb-3" style="font-size: 1rem; font-style: italic; font-weight: 400;">{svc.title}</h3>
              <p class="font-body text-sm text-muted leading-relaxed mb-6">{svc.body}</p>
              <span class="font-body text-[10px] tracking-[0.2em] uppercase text-muted group-hover:text-text transition-colors duration-200 inline-flex items-center gap-2">
                Learn more <span aria-hidden="true">&#8594;</span>
              </span>
            </a>
          </AnimateIn>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: #EEECEA; border-top: 1px solid #D5D3CB;">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16 lg:py-20">
      <AnimateIn>
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
          <div>
            <h2 class="font-serif text-text leading-[1.05]" style="font-size: clamp(1.6rem, 3vw, 2.4rem); font-style: italic; font-weight: 300;">
              Ready to build something?
            </h2>
            <p class="font-body text-sm text-muted mt-2">Let's talk about your project.</p>
          </div>
          <a href="/contact" class="inline-flex items-center gap-3 font-body text-sm bg-text px-8 py-4 hover:bg-muted transition-colors duration-200 flex-shrink-0" style="color: #F7F6F2; font-weight: 500;">Get in touch <span aria-hidden="true">&#8594;</span></a>
        </div>
      </AnimateIn>
    </div>
  </section>

</div><!-- end .light-layout -->


<!-- ================================================
     DARK LAYOUT — Expensive perfume bottle.
     Byredo. Le Labo. Maison Margiela. Almost nothing.
================================================ -->
<div class="dark-layout" aria-hidden="true">

  <!-- Section 1: HERO — centered crest -->
  <section class="dk2-hero">

    <!-- Dark hero nav -->
    <div class="dk2-hero-nav">
      <a href="/" class="dk2-hero-logo-link" aria-label="Alexandria Braniff — Home">
        <img src="/images/ab-logo.png" alt="Alexandria Braniff" class="dk2-nav-logo" />
      </a>
      <nav class="dk2-hero-nav-links">
        <a href="/about">About</a>
        <a href="/services">Services</a>
        <a href="/portfolio">Projects</a>
        <a href="/contact">Contact</a>
      </nav>
      <div class="dk2-hero-nav-right">
        <button class="theme-toggle-btn dk2-theme-btn" aria-label="Toggle dark mode">
          <svg class="icon-moon-hero" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M13.5 9.5A5.5 5.5 0 0 1 6.5 2.5a5.5 5.5 0 1 0 7 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <svg class="icon-sun-hero hidden" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="2.75" stroke="currentColor" stroke-width="1.5"/>
            <path d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.4 3.4l1.07 1.07M11.53 11.53l1.07 1.07M3.4 12.6l1.07-1.07M11.53 4.47l1.07-1.07" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <button class="dk2-hero-hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="dk2-mobile-menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>

    <!-- Dark hero mobile menu -->
    <div id="dk2-mobile-menu" class="fixed inset-0 z-40 flex-col hidden" style="background:#050505;" aria-hidden="true">
      <div class="flex items-center justify-between px-6 h-16" style="border-bottom:1px solid #1A1A1A;">
        <a href="/" aria-label="Alexandria Braniff — Home">
          <img src="/images/ab-logo.png" alt="Alexandria Braniff" style="height:2.25rem;width:2.25rem;object-fit:contain;filter:brightness(0) invert(1);" />
        </a>
        <button class="dk2-menu-close" aria-label="Close menu" style="color:rgba(255,255,255,0.4);width:2.5rem;height:2.5rem;display:flex;align-items:center;justify-content:center;">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M1 1L15 15M15 1L1 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
      <nav style="display:flex;flex-direction:column;padding:2rem 1.5rem;gap:0.25rem;">
        <a href="/about" style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1rem;color:rgba(255,255,255,0.5);padding:1rem 0;border-bottom:1px solid #1A1A1A;">About</a>
        <a href="/services" style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1rem;color:rgba(255,255,255,0.5);padding:1rem 0;border-bottom:1px solid #1A1A1A;">Services</a>
        <a href="/portfolio" style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1rem;color:rgba(255,255,255,0.5);padding:1rem 0;border-bottom:1px solid #1A1A1A;">Projects</a>
        <a href="/contact" style="font-family:'Plus Jakarta Sans',sans-serif;font-size:0.72rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:#FFFFFF;margin-top:1rem;display:inline-block;">Contact</a>
      </nav>
      <div style="padding:1rem 1.5rem;border-top:1px solid #1A1A1A;margin-top:auto;">
        <button class="theme-toggle-btn" style="display:flex;align-items:center;gap:0.75rem;color:rgba(255,255,255,0.3);font-family:'Plus Jakarta Sans',sans-serif;font-size:0.75rem;letter-spacing:0.1em;background:none;border:none;cursor:pointer;" aria-label="Toggle dark mode">
          <span class="icon-moon-hero"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.5 9.5A5.5 5.5 0 0 1 6.5 2.5a5.5 5.5 0 1 0 7 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <span class="icon-sun-hero hidden"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="2.75" stroke="currentColor" stroke-width="1.5"/><path d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.4 3.4l1.07 1.07M11.53 11.53l1.07 1.07M3.4 12.6l1.07-1.07M11.53 4.47l1.07-1.07" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
          Toggle theme
        </button>
      </div>
    </div>

    <!-- Hero body — centered crest -->
    <div class="dk2-hero-body" style="position: relative;">
      <!-- Background image -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <img src="/images/hero-bg-dark.jpg" alt="" class="w-full h-full object-cover" style="opacity: 0.18;" />
      </div>

      <!-- Name -->
      <h1 class="dk2-hero-name" style="animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) both 0.3s;">
        Alexandria Braniff
      </h1>

      <!-- Role -->
      <p class="dk2-hero-role" style="animation: fadeUp 0.7s ease-out both 0.45s;">
        Web Developer &mdash; Vancouver, BC
      </p>

      <!-- Thin horizontal rule -->
      <div class="dk2-hero-hrule" style="animation: fadeUp 0.6s ease-out both 0.5s;"></div>

      <!-- Tagline -->
      <p class="dk2-hero-tagline" style="animation: fadeUp 0.7s ease-out both 0.55s;">
        Custom websites for small businesses that want to look like they mean it online.
      </p>

      <!-- CTAs -->
      <div class="dk2-hero-ctas" style="animation: fadeUp 0.7s ease-out both 0.65s;">
        <a href="/portfolio" class="dk2-hero-cta-ghost">View all work</a>
        <a href="/contact" class="dk2-hero-cta">Start a project</a>
      </div>
    </div>

  </section>

  <!-- Section 2: STATEMENT — one sentence, vast space -->
  <section class="dk2-statement">
    <p class="dk2-statement-text">
      The kind of site that makes people stop and ask — where did you get that made?
    </p>
  </section>

  <!-- Section 3: SELECTED WORK -->
  <section class="dk2-work">
    <div class="dk2-work-label-row">
      <span class="dk2-tiny-label">Selected Work</span>
      <div class="dk2-rule"></div>
    </div>
    <div class="dk2-work-grid">
      {featuredProjects.map((project, i) => (
        <AnimateIn delay={i * 100}>
          <ProjectCard project={project} />
        </AnimateIn>
      ))}
    </div>
    <div class="dk2-work-footer">
      <a href="/portfolio" class="dk2-view-all">View all work &#8594;</a>
    </div>
  </section>

  <!-- Section 4: CTA — white reversal -->
  <section class="dk2-cta">
    <div class="dk2-cta-inner">
      <span class="dk2-cta-label">Ready when you are</span>
      <h2 class="dk2-cta-heading">
        Let's build<br />something<br />worth finding.
      </h2>
      <a href="/contact" class="dk2-cta-btn">Get in touch</a>
    </div>
  </section>

</div><!-- end .dark-layout -->

</Layout>

<style>
  /* ---- Layout visibility toggle ---- */
  .light-layout { display: block; }
  .dark-layout  { display: none;  }

  /* Light hero — crest sizing */
  .hero-crest-logo {
    width: clamp(140px, 22vw, 220px);
    height: clamp(140px, 22vw, 220px);
