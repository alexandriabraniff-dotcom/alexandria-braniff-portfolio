---
// Homepage — dual layout: light "selling flowers" / dark "expensive perfume bottle"
import Layout from '../layouts/Layout.astro';
import AnimateIn from '../components/AnimateIn.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';

// Only show real (non-coming-soon) projects on the homepage
const featuredProjects = projects.filter(p => !p.comingSoon);
---

<Layout
  title="Alexandria Braniff — Web Developer for Small Businesses"
  description="Custom websites for small businesses. Designed and built from scratch by Alexandria Braniff, web developer in Vancouver, BC."
  heroNav={true}
>

<!-- ================================================
     LIGHT LAYOUT — Selling flowers. Delicate, romantic, elegant.
================================================ -->
<div class="light-layout">

  <!-- HERO -->
  <section id="hero" class="relative overflow-hidden border-b border-surface2">
    <!-- Integrated hero nav bar (replaces old top-bar) -->
    <nav class="hero-nav-bar flex items-center justify-between px-6 lg:px-12 h-16 lg:h-[4.5rem] border-b border-surface2">
      <a href="/" class="font-display font-bold text-text text-sm tracking-[-0.02em] hover:text-muted transition-colors duration-200">Alexandria Braniff</a>
      <div class="hidden md:flex items-center gap-10">
        <a href="/about" class="font-body text-[11px] font-medium tracking-[0.08em] uppercase text-muted hover:text-text transition-colors duration-200 relative py-1 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-text hover:after:w-full after:transition-all after:duration-200">About</a>
        <a href="/portfolio" class="font-body text-[11px] font-medium tracking-[0.08em] uppercase text-muted hover:text-text transition-colors duration-200 relative py-1 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-text hover:after:w-full after:transition-all after:duration-200">Portfolio</a>
        <a href="/contact" class="font-body text-[11px] font-semibold tracking-[0.12em] uppercase text-text hover:text-muted transition-colors duration-200">Get in touch</a>
      </div>
      <div class="flex items-center gap-1">
        <button class="theme-toggle-btn w-9 h-9 flex items-center justify-center text-muted hover:text-text transition-colors duration-200" aria-label="Toggle dark mode">
          <svg class="icon-moon-hero" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M13.5 9.5A5.5 5.5 0 0 1 6.5 2.5a5.5 5.5 0 1 0 7 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <svg class="icon-sun-hero hidden" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="2.75" stroke="currentColor" stroke-width="1.5"/>
            <path d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.4 3.4l1.07 1.07M11.53 11.53l1.07 1.07M3.4 12.6l1.07-1.07M11.53 4.47l1.07-1.07" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <button class="hero-hamburger md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5" aria-label="Open menu" aria-expanded="false" aria-controls="hero-mobile-menu">
          <span class="hero-ham-line block w-5 h-0.5 bg-text transition-all duration-300 origin-center"></span>
          <span class="hero-ham-line block w-5 h-0.5 bg-text transition-all duration-300 origin-center"></span>
          <span class="hero-ham-line block w-5 h-0.5 bg-text transition-all duration-300 origin-center"></span>
        </button>
      </div>
    </nav>

    <!-- Hero mobile menu overlay -->
    <div id="hero-mobile-menu" class="fixed inset-0 z-40 bg-base flex-col hidden" aria-hidden="true" role="dialog" aria-label="Navigation menu">
      <div class="flex items-center justify-between px-6 h-16 border-b border-surface2">
        <a href="/" class="font-display font-bold text-text text-sm tracking-[-0.02em]">Alexandria Braniff</a>
        <button class="hero-menu-close w-10 h-10 flex items-center justify-center text-muted hover:text-text" aria-label="Close menu">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M1 1L15 15M15 1L1 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      </div>
      <nav class="flex flex-col px-6 py-8 gap-1">
        <a href="/about" class="font-body text-base font-medium py-4 border-b border-surface2 text-muted hover:text-text transition-colors">About</a>
        <a href="/portfolio" class="font-body text-base font-medium py-4 border-b border-surface2 text-muted hover:text-text transition-colors">Portfolio</a>
        <a href="/contact" class="font-body text-sm font-semibold tracking-[0.1em] uppercase text-text border-b border-text pb-0.5 mt-4 inline-block hover:text-muted hover:border-muted transition-colors">Get in touch</a>
      </nav>
      <div class="px-6 pt-4 border-t border-surface2 mt-auto">
        <button class="theme-toggle-btn flex items-center gap-3 font-body text-sm text-muted hover:text-text transition-colors py-2" aria-label="Toggle dark mode">
          <span class="icon-moon-hero"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.5 9.5A5.5 5.5 0 0 1 6.5 2.5a5.5 5.5 0 1 0 7 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <span class="icon-sun-hero hidden"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="2.75" stroke="currentColor" stroke-width="1.5"/><path d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.4 3.4l1.07 1.07M11.53 11.53l1.07 1.07M3.4 12.6l1.07-1.07M11.53 4.47l1.07-1.07" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
          <span>Toggle theme</span>
        </button>
      </div>
    </div>

    <!-- Hero content grid -->
    <div class="grid lg:grid-cols-[1fr_440px]" style="min-height: calc(100vh - 4.5rem);">
      <div class="flex flex-col px-6 lg:px-12 py-12 lg:py-16 border-r border-surface2 relative">
        <div class="flex items-center gap-3 mb-6" style="animation: fadeUp 0.5s ease-out both;">
          <div class="w-8 h-8 bg-text flex items-center justify-center flex-shrink-0">
            <span class="font-display font-bold" style="color: #F7F6F2; font-size: 9px; letter-spacing: 0.08em;">AB</span>
          </div>
          <span class="font-body text-[10px] tracking-[0.25em] uppercase text-muted">Web Developer</span>
        </div>
        <div class="overflow-hidden mb-10">
          <div class="h-px bg-surface2" style="animation: drawLineX 1s ease-out both 0.6s; transform-origin: left;"></div>
        </div>
        <div class="flex-1 flex flex-col justify-center">
          <h1 class="font-serif text-text leading-[0.92] mb-10" style="font-size: clamp(3.5rem, 7vw, 7.5rem); font-style: italic; font-weight: 300;">
            <span class="block" style="animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) both 0.1s;">Websites that</span>
            <span class="block" style="animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) both 0.3s;">never stand still.</span>
          </h1>
          <p class="font-body text-sm text-muted leading-relaxed max-w-[280px] mb-12" style="animation: fadeUp 0.7s ease-out both 0.5s;">
            Custom sites for small businesses that want to look like they mean it online. Designed and built from scratch. No templates.
          </p>
          <div class="flex flex-col sm:flex-row gap-3" style="animation: fadeUp 0.7s ease-out both 0.6s;">
            <a href="/portfolio" data-magnetic class="flex justify-center font-body text-sm text-text border border-surface2 px-6 py-3 hover:border-text transition-colors duration-200">View all work</a>
            <a href="/contact" data-magnetic class="flex justify-center font-body text-sm bg-text px-6 py-3 hover:bg-muted transition-colors duration-200" style="color: #F7F6F2; font-weight: 500;">Get in touch</a>
          </div>
        </div>
      </div>
      <div class="relative hidden lg:block bg-surface overflow-hidden" data-cursor="view">
        <img src="https://picsum.photos/seed/alexa-hero/880/1080" alt="Featured project" class="absolute inset-0 w-full h-full object-cover" data-parallax="0.15" />
        <div class="absolute bottom-6 left-6 z-10">
          <div class="inline-flex items-center gap-2 bg-base border border-surface2 px-3 py-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-text flex-shrink-0"></span>
            <span class="font-body text-[10px] tracking-[0.2em] uppercase text-muted">Featured Work</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INTRO — restructured 2-column with large portrait -->
  <section class="px-6 lg:px-12 py-20 lg:py-28 border-b border-surface2">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-[1fr_400px] gap-12 lg:gap-16 items-stretch">

        <!-- Text column -->
        <div class="flex flex-col justify-center gap-8 py-4">
          <span class="font-body text-[10px] tracking-[0.25em] uppercase text-muted">01</span>
          <AnimateIn>
            <h2 class="font-serif text-text" style="font-size: clamp(1.6rem, 3vw, 2.4rem); line-height: 1.2; font-style: italic; font-weight: 300;">Small business websites,<br>done properly.</h2>
          </AnimateIn>
          <AnimateIn delay={100}>
            <div class="space-y-4 font-body text-sm text-muted leading-relaxed max-w-md">
              <p>I'm Alexandria. I build custom websites for small businesses that want to look like they mean it online. Not a template. Not a drag-and-drop builder.</p>
              <p>Every project starts with a real conversation. I find out what you do, who your customers are, and what you need the site to achieve. Then I build it from scratch.</p>
              <a href="/about" class="inline-flex items-center gap-2 font-body text-xs font-semibold tracking-[0.15em] uppercase text-text border-b border-text pb-0.5 mt-2 hover:text-muted hover:border-muted transition-colors duration-200">About me &#8594;</a>
            </div>
          </AnimateIn>
        </div>

        <!-- Portrait column — large, prominent -->
        <AnimateIn delay={150}>
          <div class="placeholder-img warm lg:min-h-[520px] min-h-[300px]">
            <img src="https://picsum.photos/seed/alexa-portrait/800/1040" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
          </div>
        </AnimateIn>

      </div>
    </div>
  </section>

  <!-- SELECTED WORK -->
  <section class="px-6 lg:px-12 py-16 lg:py-24 border-b border-surface2">
    <div class="max-w-7xl mx-auto">
      <AnimateIn>
        <div class="flex items-center gap-6 mb-8">
          <span class="font-body text-[10px] tracking-[0.25em] uppercase text-muted flex-shrink-0">02</span>
          <div class="h-px bg-surface2 flex-1"></div>
          <span class="font-serif text-text flex-shrink-0" style="font-size: 1rem; font-style: italic; font-weight: 400;">Selected Work</span>
        </div>
      </AnimateIn>
      <AnimateIn>
        <div class="placeholder-img gold-tone w-full mb-8 hidden lg:flex" style="height: 120px;">
          <img src="https://picsum.photos/seed/alexa-strip/1400/240" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
        </div>
      </AnimateIn>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
        {featuredProjects.map((project, i) => (
          <AnimateIn delay={i * 100}><ProjectCard project={project} /></AnimateIn>
        ))}
      </div>
      <AnimateIn>
        <div class="mt-6">
          <a href="/portfolio" class="inline-flex items-center gap-3 font-body text-sm font-medium text-text hover:text-muted transition-colors duration-200">
            <span class="h-px w-6 bg-text inline-block"></span>View all work
          </a>
        </div>
      </AnimateIn>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="px-6 lg:px-12 py-16 lg:py-24 border-b border-surface2">
    <div class="max-w-7xl mx-auto">
      <AnimateIn>
        <div class="flex items-center gap-6 mb-14">
          <span class="font-body text-[10px] tracking-[0.25em] uppercase text-muted flex-shrink-0">03</span>
          <div class="h-px bg-surface2 flex-1"></div>
          <span class="font-serif text-text flex-shrink-0" style="font-size: 1rem; font-style: italic; font-weight: 400;">What I Do</span>
        </div>
      </AnimateIn>
      <div class="divide-y divide-surface2 -mx-6 lg:-mx-12">
        {[
          { n: '01', title: 'Website Design & Build', body: 'A complete custom website designed and built around your business. From first conversation to launch day, I handle everything.' },
          { n: '02', title: 'Custom Development', body: "Need something specific that off-the-shelf tools can't handle? I build custom functionality to spec — booking flows, integrations, and more." },
          { n: '03', title: 'Site Maintenance', body: 'Monthly plans keep your site updated, secure, and running well. No more chasing someone for a simple content change.' },
          { n: '04', title: 'Digital Setup & Tech', body: 'Domain, hosting, business email, Google Business Profile, analytics. I handle the full digital setup so your presence actually works.' },
        ].map((svc, i) => (
          <AnimateIn delay={i * 60}>
            <div class="service-row grid lg:grid-cols-[80px_1fr_1fr] gap-4 lg:gap-12 py-7 px-6 lg:px-12 group hover:bg-surface transition-colors duration-200">
              <span class="font-serif text-3xl text-surface2 leading-none group-hover:text-muted transition-colors duration-300" style="font-weight: 300; font-style: italic;">{svc.n}</span>
              <h3 class="font-serif text-text self-center" style="font-size: 1.05rem; font-style: italic; font-weight: 400;">{svc.title}</h3>
              <p class="font-body text-sm text-muted leading-relaxed self-center">{svc.body}</p>
            </div>
          </AnimateIn>
        ))}
      </div>
      <div class="mt-12 hidden lg:block">
        <div class="placeholder-img warm" style="height: 200px;">
          <img src="https://picsum.photos/seed/alexa-process/1400/400" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 lg:px-12 py-24 lg:py-36">
    <div class="max-w-7xl mx-auto">
      <AnimateIn>
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-10">
          <div>
            <div class="h-px bg-gold mb-10 hidden lg:block" style="width: 48px;"></div>
            <h2 class="font-serif text-text leading-[0.92]" style="font-size: clamp(2.8rem, 7.5vw, 8rem); font-style: italic; font-weight: 300;">
              Ready to build<br />something<br />beautiful.
            </h2>
          </div>
          <div class="flex flex-col items-start lg:items-end gap-5">
            <p class="font-body text-sm text-muted">Let's talk about your project.</p>
            <a href="/contact" data-magnetic class="inline-flex items-center gap-3 font-body text-sm bg-text px-8 py-4 hover:bg-muted transition-colors duration-200" style="color: #F7F6F2; font-weight: 500;">Get in touch <span aria-hidden="true">&#8594;</span></a>
          </div>
        </div>
      </AnimateIn>
    </div>
  </section>

</div><!-- end .light-layout -->


<!-- ================================================
     DARK LAYOUT — Expensive perfume bottle.
     Byredo. Le Labo. Maison Margiela. Almost nothing.
================================================ -->
<div class="dark-layout" aria-hidden="true">

  <!-- Section 1: HERO — cinematic split -->
  <section class="dk2-hero">
    <!-- Left 62% -->
    <div class="dk2-hero-left">

      <!-- Integrated dark hero nav -->
      <div class="dk2-hero-nav">
        <a href="/" class="dk2-hero-wordmark">Alexandria Braniff</a>
        <nav class="dk2-hero-nav-links">
          <a href="/about">About</a>
          <a href="/portfolio">Portfolio</a>
          <a href="/contact">Get in touch</a>
        </nav>
        <div class="dk2-hero-nav-right">
          <button class="theme-toggle-btn dk2-theme-btn" aria-label="Toggle dark mode">
            <svg class="icon-moon-hero" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M13.5 9.5A5.5 5.5 0 0 1 6.5 2.5a5.5 5.5 0 1 0 7 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <svg class="icon-sun-hero hidden" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="2.75" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.4 3.4l1.07 1.07M11.53 11.53l1.07 1.07M3.4 12.6l1.07-1.07M11.53 4.47l1.07-1.07" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
          <button class="dk2-hero-hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="dk2-mobile-menu">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>

      <!-- Dark hero mobile menu -->
      <div id="dk2-mobile-menu" class="fixed inset-0 z-40 flex-col hidden" style="background:#050505;" aria-hidden="true">
        <div class="flex items-center justify-between px-6 h-16" style="border-bottom:1px solid #1A1A1A;">
          <span style="font-family:'Cormorant Garant',serif;font-style:italic;font-weight:300;color:rgba(255,255,255,0.7);font-size:1rem;">Alexandria Braniff</span>
          <button class="dk2-menu-close" aria-label="Close menu" style="color:rgba(255,255,255,0.4);width:2.5rem;height:2.5rem;display:flex;align-items:center;justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M1 1L15 15M15 1L1 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
        </div>
        <nav style="display:flex;flex-direction:column;padding:2rem 1.5rem;gap:0.25rem;">
          <a href="/about" style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1rem;color:rgba(255,255,255,0.5);padding:1rem 0;border-bottom:1px solid #1A1A1A;">About</a>
          <a href="/portfolio" style="font-family:'Plus Jakarta Sans',sans-serif;font-size:1rem;color:rgba(255,255,255,0.5);padding:1rem 0;border-bottom:1px solid #1A1A1A;">Portfolio</a>
          <a href="/contact" style="font-family:'Plus Jakarta Sans',sans-serif;font-size:0.72rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:#FFFFFF;margin-top:1rem;display:inline-block;">Get in touch</a>
        </nav>
        <div style="padding:1rem 1.5rem;border-top:1px solid #1A1A1A;margin-top:auto;">
          <button class="theme-toggle-btn" style="display:flex;align-items:center;gap:0.75rem;color:rgba(255,255,255,0.3);font-family:'Plus Jakarta Sans',sans-serif;font-size:0.75rem;letter-spacing:0.1em;background:none;border:none;cursor:pointer;" aria-label="Toggle dark mode">
            <span class="icon-moon-hero"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.5 9.5A5.5 5.5 0 0 1 6.5 2.5a5.5 5.5 0 1 0 7 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            <span class="icon-sun-hero hidden"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="2.75" stroke="currentColor" stroke-width="1.5"/><path d="M8 1.5V3M8 13v1.5M1.5 8H3M13 8h1.5M3.4 3.4l1.07 1.07M11.53 11.53l1.07 1.07M3.4 12.6l1.07-1.07M11.53 4.47l1.07-1.07" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></span>
            Toggle theme
          </button>
        </div>
      </div>

      <div class="dk2-hero-headline-wrap">
        <h1 class="dk2-hero-headline">
          <span class="dk2-hl-line" style="animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) both 0.1s;">Built for</span>
          <span class="dk2-hl-line" style="animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) both 0.25s;">businesses</span>
          <span class="dk2-hl-line dk2-hl-muted" style="animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) both 0.4s;">that mean it.</span>
        </h1>
      </div>

      <div class="dk2-hero-bottom">
        <p class="dk2-hero-body-text">Custom sites for small businesses. No templates. No handoffs.</p>
        <a href="/contact" class="dk2-hero-cta">Start a project</a>
      </div>
    </div>

    <!-- Right 38%: image -->
    <div class="dk2-hero-right">
      <img src="https://picsum.photos/seed/alexa-hero/880/1080" alt="" loading="lazy" class="dk2-hero-img" />
    </div>
  </section>

  <!-- Section 2: STATEMENT — one sentence, vast space -->
  <section class="dk2-statement">
    <p class="dk2-statement-text">
      The kind of site that makes people stop and ask — where did you get that made?
    </p>
  </section>

  <!-- Section 3: SELECTED WORK -->
  <section class="dk2-work">
    <div class="dk2-work-label-row">
      <span class="dk2-tiny-label">Selected Work</span>
      <div class="dk2-rule"></div>
    </div>
    <div class="dk2-work-grid">
      {featuredProjects.map((project, i) => (
        <AnimateIn delay={i * 100}>
          <ProjectCard project={project} />
        </AnimateIn>
      ))}
    </div>
    <div class="dk2-work-footer">
      <a href="/portfolio" class="dk2-view-all">View all work &#8594;</a>
    </div>
  </section>

  <!-- Section 4: CTA — white reversal -->
  <section class="dk2-cta">
    <div class="dk2-cta-inner">
      <span class="dk2-cta-label">Ready when you are</span>
      <h2 class="dk2-cta-heading">
        Let's build<br />something<br />worth finding.
      </h2>
      <a href="/contact" class="dk2-cta-btn">Get in touch</a>
    </div>
  </section>

</div><!-- end .dark-layout -->

</Layout>

<style>
  /* ---- Layout visibility toggle ---- */
  .light-layout { display: block; }
  .dark-layout  { display: none;  }

  /* ════════════════════════════════════
     DARK LAYOUT — Perfume bottle luxury
  ════════════════════════════════════ */

  /* HERO */
  .dk2-hero {
    display: grid;
    grid-template-columns: 62fr 38fr;
    min-height: 100vh;
    border-bottom: 1px solid #1A1A1A;
    overflow: hidden;
  }
  @media (max-width: 900px) {
    .dk2-hero { grid-template-columns: 1fr; }
    .dk2-hero-right { display: none; }
  }

  .dk2-hero-left {
    display: flex;
    flex-direction: column;
    padding: 0;
    border-right: 1px solid #1A1A1A;
  }

  /* Dark hero nav */
  .dk2-hero-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 3rem;
    height: 4.5rem;
    border-bottom: 1px solid #1A1A1A;
    gap: 2rem;
