    text-decoration: none;
    transition: background 0.2s;
  }
  .dk2-cta-btn:hover { background: #1A1A1A; }
</style>

<script>
  // Parallax for light layout hero image
  const parallaxEls = document.querySelectorAll('[data-parallax]');
  function updateParallax() {
    const scrollY = window.scrollY;
    parallaxEls.forEach((el) => {
      const rate = parseFloat((el as HTMLElement).dataset.parallax || '0.15');
      (el as HTMLElement).style.transform = `translateY(${scrollY * rate}px)`;
    });
  }
  window.addEventListener('scroll', updateParallax, { passive: true });

  // Toggle layout visibility when theme changes
  function syncLayouts() {
    const isDark = document.documentElement.classList.contains('dark');
    const light = document.querySelector('.light-layout') as HTMLElement | null;
    const dark  = document.querySelector('.dark-layout')  as HTMLElement | null;
    if (light) { light.style.display = isDark ? 'none' : 'block'; light.setAttribute('aria-hidden', isDark ? 'true' : 'false'); }
    if (dark)  { dark.style.display  = isDark ? 'block' : 'none'; dark.setAttribute('aria-hidden',  isDark ? 'false' : 'true'); }
  }

  syncLayouts();

  // Watch for theme changes triggered by the toggle button
  const observer = new MutationObserver(syncLayouts);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

  // ── Theme toggle — handle all .theme-toggle-btn buttons ──
  function applyTheme(dark: boolean) {
    document.documentElement.classList.toggle('dark', dark);
    localStorage.setItem('theme', dark ? 'dark' : 'light');
    // Update header toggle icons (sticky header)
    const iconMoon = document.getElementById('icon-moon');
    const iconSun = document.getElementById('icon-sun');
    if (iconMoon) iconMoon.style.display = dark ? 'none' : '';
    if (iconSun) iconSun.style.display = dark ? '' : 'none';
    // Update all hero toggle icons (light and dark layouts)
    document.querySelectorAll('.icon-moon-hero').forEach(el => (el as HTMLElement).style.display = dark ? 'none' : 'block');
    document.querySelectorAll('.icon-sun-hero').forEach(el => (el as HTMLElement).style.display = dark ? 'block' : 'none');
  }

  // Sync icons on load
  applyTheme(document.documentElement.classList.contains('dark'));

  // Wire up all theme toggle buttons on this page
  document.querySelectorAll('.theme-toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => applyTheme(!document.documentElement.classList.contains('dark')));
  });

  // ── Scroll-triggered sticky header ──
  const siteHeader = document.getElementById('site-header');
  const lightHeroEl = document.getElementById('hero');
  const darkHeroEl = document.querySelector('.dk2-hero') as HTMLElement | null;

  function updateHeaderOnScroll() {
    const isDark = document.documentElement.classList.contains('dark');
    const activeHero = isDark ? darkHeroEl : lightHeroEl;
    if (!siteHeader || !activeHero) return;
    const rect = activeHero.getBoundingClientRect();
    const heroGone = rect.bottom <= 0;
    if (heroGone) {
      siteHeader.style.transform = 'translateY(0)';
      siteHeader.style.opacity = '1';
    } else {
      siteHeader.style.transform = 'translateY(-100%)';
      siteHeader.style.opacity = '0';
    }
  }

  window.addEventListener('scroll', updateHeaderOnScroll, { passive: true });
  // Re-check when theme changes (different hero element is active)
  const themeChangeObserver = new MutationObserver(() => updateHeaderOnScroll());
  themeChangeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  updateHeaderOnScroll();

  // ── Light hero mobile menu ──
  const heroHamburger = document.querySelector('.hero-hamburger') as HTMLButtonElement | null;
  const heroMobileMenu = document.getElementById('hero-mobile-menu');
  const heroMenuClose = document.querySelector('.hero-menu-close') as HTMLButtonElement | null;

  function openHeroMenu() {
    if (!heroMobileMenu) return;
    heroMobileMenu.classList.remove('hidden');
    heroMobileMenu.style.display = 'flex';
    heroMobileMenu.setAttribute('aria-hidden', 'false');
    heroHamburger?.setAttribute('aria-expanded', 'true');
    document.documentElement.style.overflow = 'hidden';
  }

  function closeHeroMenu() {
    if (!heroMobileMenu) return;
    heroMobileMenu.classList.add('hidden');
    heroMobileMenu.style.display = '';
    heroMobileMenu.setAttribute('aria-hidden', 'true');
    heroHamburger?.setAttribute('aria-expanded', 'false');
    document.documentElement.style.overflow = '';
  }

  heroHamburger?.addEventListener('click', openHeroMenu);
  heroMenuClose?.addEventListener('click', closeHeroMenu);
  heroMobileMenu?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeHeroMenu));

  // ── Dark hero mobile menu ──
  const dk2Hamburger = document.querySelector('.dk2-hero-hamburger') as HTMLButtonElement | null;
  const dk2MobileMenu = document.getElementById('dk2-mobile-menu');
  const dk2MenuClose = document.querySelector('.dk2-menu-close') as HTMLButtonElement | null;

  function openDk2Menu() {
    if (!dk2MobileMenu) return;
    dk2MobileMenu.classList.remove('hidden');
    dk2MobileMenu.style.display = 'flex';
    dk2MobileMenu.setAttribute('aria-hidden', 'false');
    dk2Hamburger?.setAttribute('aria-expanded', 'true');
    document.documentElement.style.overflow = 'hidden';
  }

  function closeDk2Menu() {
    if (!dk2MobileMenu) return;
    dk2MobileMenu.classList.add('hidden');
    dk2MobileMenu.style.display = '';
    dk2MobileMenu.setAttribute('aria-hidden', 'true');
    dk2Hamburger?.setAttribute('aria-expanded', 'false');
    document.documentElement.style.overflow = '';
  }

  dk2Hamburger?.addEventListener('click', openDk2Menu);
  dk2MenuClose?.addEventListener('click', closeDk2Menu);
  dk2MobileMenu?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeDk2Menu));
</script>
