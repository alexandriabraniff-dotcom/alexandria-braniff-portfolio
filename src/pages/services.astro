---
import Layout from '../layouts/Layout.astro';
import AnimateIn from '../components/AnimateIn.astro';

const services = [
  {
    id: 'audits',
    title: 'Website Audits',
    price: '$199',
    blurb: 'A thorough review of your existing website — performance, SEO, design, and user experience.',
    detail: 'Got a site that\'s not converting or feels outdated? I\'ll audit every aspect — load speed, SEO foundations, mobile responsiveness, design consistency, and user flow — and hand you a clear, actionable report. You walk away knowing exactly what\'s holding your site back and what to fix first.',
    includes: ['Performance & speed audit', 'SEO health check', 'Mobile & accessibility review', 'Design & UX assessment', 'Written report with action steps'],
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M19 19l5 5"/><path d="M9 12h6M12 9v6"/></svg>`,
  },
  {
    id: 'web-design',
    title: 'Website Design & Development',
    price: null,
    blurb: 'A complete custom website, designed and built around your business from scratch.',
    detail: 'From the first conversation to launch day, I handle everything — design, development, copywriting guidance, domain setup, and deployment. No templates, no page builders, no shortcuts. You get a site that looks like yours and performs from day one.',
    includes: ['Custom design tailored to your brand', 'Responsive across all devices', 'SEO foundations built in', 'Fast, clean code', 'Full launch support'],
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="24" height="18" rx="2"/><path d="M8 10l4 4-4 4M14 18h6"/></svg>`,
  },
  {
    id: 'maintenance',
    title: 'Website Maintenance',
    price: null,
    blurb: 'Ongoing care so your site stays fast, secure, and up to date after launch.',
    detail: 'Websites need attention after they go live. I offer monthly maintenance plans that cover content updates, security patches, performance monitoring, and anything that keeps your site running well. No more chasing someone for a small change.',
    includes: ['Content updates', 'Security & plugin patches', 'Performance monitoring', 'Monthly reporting', 'Priority support'],
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4v4M14 20v4M4 14H8M20 14h4"/><circle cx="14" cy="14" r="5"/><path d="M6.34 6.34l2.83 2.83M18.83 18.83l2.83 2.83M6.34 21.66l2.83-2.83M18.83 9.17l2.83-2.83"/></svg>`,
  },
  {
    id: 'seo',
    title: 'Search Engine Optimisation',
    price: null,
    blurb: 'Get found on Google by the people who are already looking for what you offer.',
    detail: 'SEO isn\'t magic — it\'s structure, content, and consistency. I build SEO foundations into every site I create, and offer ongoing optimisation for businesses that want to grow their organic visibility over time. Local SEO, on-page optimisation, and technical fixes included.',
    includes: ['On-page SEO setup', 'Local SEO (Google Business)', 'Technical SEO fixes', 'Keyword research', 'Monthly performance reporting'],
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20l5-8 4 5 4-6 5 9"/><circle cx="14" cy="8" r="3"/></svg>`,
  },
  {
    id: 'uiux',
    title: 'UI/UX Design',
    price: null,
    blurb: 'Interface design focused on how people actually use your site — not just how it looks.',
    detail: 'Good design is invisible. I approach every project with user flow and conversion in mind — where people land, what they see first, what makes them stay, and what gets them to act. I offer standalone UI/UX design for businesses that already have developers, or as part of a full build.',
    includes: ['User flow mapping', 'Wireframes & mockups', 'Component design', 'Mobile-first layouts', 'Handoff-ready design files'],
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="10" height="10" rx="1"/><rect x="15" y="3" width="10" height="6" rx="1"/><rect x="15" y="13" width="10" height="12" rx="1"/><rect x="3" y="17" width="10" height="8" rx="1"/></svg>`,
  },
  {
    id: 'ecommerce',
    title: 'E-commerce Integrations',
    price: null,
    blurb: 'Add online selling to your existing site or build a store from the ground up.',
    detail: 'Whether you need a full e-commerce store or just want to add a shop to your existing site, I can integrate the right solution for your business. Stripe, Shopify, Snipcart, and more — set up properly so you can sell from day one without the tech headaches.',
    includes: ['Payment gateway setup', 'Product catalogue build', 'Cart & checkout flow', 'Inventory & order management', 'Mobile-optimised shopping'],
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h3l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L25 8H7"/><circle cx="10" cy="23" r="1.5"/><circle cx="21" cy="23" r="1.5"/></svg>`,
  },
  {
    id: 'digital-setup',
    title: 'Digital Infrastructure Setup',
    price: null,
    blurb: 'Everything behind the scenes that makes your online presence function properly from day one.',
    detail: 'A great website is only part of the picture. I handle the full digital setup that surrounds it — domain and hosting configuration, professional business email, Google Business Profile, analytics tracking, and any third-party integrations your business depends on. Done right the first time.',
    includes: ['Domain registration & DNS setup', 'Hosting configuration', 'Professional business email', 'Google Business Profile setup', 'Analytics & tracking installation'],
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="24" height="16" rx="2"/><path d="M8 14h.01M13 14h.01M18 14h.01M2 10h24"/></svg>`,
  },
  {
    id: 'brand',
    title: 'Brand Redesign',
    price: null,
    blurb: 'Refresh your visual identity so it actually reflects where your business is heading.',
    detail: 'Your brand is more than a logo. I help small businesses clarify their visual identity — colours, typography, logo suite, and the overall look and feel that carries across your site, your socials, and your printed materials. Whether it\'s a full rebrand or a refinement, I\'ll make sure it\'s consistent and intentional.',
    includes: ['Logo design & variations', 'Colour palette', 'Typography selection', 'Brand style guide', 'Application across key touchpoints'],
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="14" cy="14" r="10"/><path d="M14 4a10 10 0 0 1 7.07 17.07"/><path d="M9 9h.01M14 7h.01M19 11h.01M17 17h.01M11 19h.01"/></svg>`,
  },
];
---

<Layout
  title="Services — Alexandria Braniff"
  description="Web design, development, SEO, maintenance and brand work for small businesses. Built from scratch by Alexandria Braniff, Vancouver BC."
>

  <!-- ============================================
       LIGHT LAYOUT
  ============================================ -->
  <div class="light-layout">

    <!-- HEADER -->
    <section class="border-b border-surface2 relative overflow-hidden">
      <img src="/images/page-header-bg.jpg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover pointer-events-none" style="opacity: 0.35;" />
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-10 lg:py-14 relative z-10">
        <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-4">Services</p>
        <h1 class="font-serif text-text leading-[0.95]" style="font-size: clamp(2rem, 4vw, 3.5rem); font-style: italic; font-weight: 300; animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) both 0.1s;">
          What I do for<br />your business.
        </h1>
        <p class="font-body text-sm text-muted max-w-md mt-4" style="animation: fadeUp 0.7s ease-out both 0.3s;">
          Every service is delivered by one person. No templates, no shortcuts, no handoffs.
        </p>
      </div>
    </section>

    <!-- SERVICE CARDS -->
    <section class="px-6 lg:px-12 py-12 lg:py-16">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {services.map((svc, i) => (
            <AnimateIn delay={i * 60}>
              <div class="flex flex-col overflow-hidden h-full" style="border: 1px solid #E8E6E0; background: #fff;">
                <!-- Icon area -->
                <div class="flex items-center justify-center p-10" style="background: #F7F6F2; min-height: 140px;">
                  <div class="text-text" set:html={svc.icon} />
                </div>
                <!-- Info -->
                <div class="flex flex-col items-center text-center px-7 pt-7 pb-7 flex-1">
                  {svc.price && (
                    <span class="font-body text-[10px] tracking-[0.2em] uppercase text-muted mb-2">{svc.price}</span>
                  )}
                  <h2 class="font-display font-bold text-text mb-4" style="font-size: 1.1rem; font-weight: 700;">{svc.title}</h2>
                  <p class="font-body text-sm text-muted leading-relaxed mb-7 flex-1">{svc.blurb}</p>
                  <button
                    class="svc-modal-trigger w-full inline-flex items-center justify-center font-body text-sm font-semibold py-3.5 transition-colors duration-200"
                    style="background: #111; color: #fff; letter-spacing: 0.02em;"
                    data-service={svc.id}
                    onmouseover="this.style.background='#333'"
                    onmouseout="this.style.background='#111'"
                  >
                    Learn More
                  </button>
                </div>
              </div>
            </AnimateIn>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section style="background: #EEECEA; border-top: 1px solid #D5D3CB;">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16 lg:py-20">
        <AnimateIn>
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
            <div>
              <h2 class="font-serif text-text leading-[1.05]" style="font-size: clamp(1.6rem, 3vw, 2.4rem); font-style: italic; font-weight: 300;">
                Ready to get started?
              </h2>
              <p class="font-body text-sm text-muted mt-2">Let's talk about your project.</p>
            </div>
            <a href="/contact" class="inline-flex items-center gap-3 font-body text-sm bg-text px-8 py-4 hover:bg-muted transition-colors duration-200 flex-shrink-0" style="color: #F7F6F2; font-weight: 500;">
              Get in touch <span aria-hidden="true">&#8594;</span>
            </a>
          </div>
        </AnimateIn>
      </div>
    </section>

  </div><!-- end .light-layout -->


  <!-- ============================================
       DARK LAYOUT
  ============================================ -->
  <div class="dark-layout">

    <!-- HEADER -->
    <section class="dk-svc-hero">
      <div class="dk-svc-hero-inner">
        <span class="dk-svc-label">Services</span>
        <h1 class="dk-svc-heading">What I do<br /><span class="dk-svc-h-muted">for you.</span></h1>
        <p class="dk-svc-sub">Everything built from scratch. One person. No handoffs.</p>
      </div>
    </section>

    <!-- SERVICE ROWS -->
    {services.map((svc) => (
      <section class="dk-svc-row">
        <div class="dk-svc-row-left">
          <h2 class="dk-svc-row-title">{svc.title}</h2>
          <p class="dk-svc-row-body">{svc.blurb}</p>
        </div>
        <div class="dk-svc-row-right">
          <p class="dk-svc-items-label">What's included</p>
          <ul class="dk-svc-items">
            {svc.includes.map(item => <li>{item}</li>)}
          </ul>
        </div>
      </section>
    ))}

    <!-- CTA -->
    <section class="dk-svc-cta">
      <div class="dk-svc-cta-inner">
        <span class="dk-svc-cta-label">Ready</span>
        <h2 class="dk-svc-cta-heading">Let's build<br />something.</h2>
        <a href="/contact" class="dk-svc-cta-btn">Get in touch &#8594;</a>
      </div>
    </section>

  </div><!-- end .dark-layout -->

  <!-- ============================================
       SERVICE MODALS (shared)
  ============================================ -->
  {services.map(svc => (
    <div
      id={`svc-modal-${svc.id}`}
      class="svc-modal fixed inset-0 z-50 hidden items-center justify-center p-6"
      style="background: rgba(0,0,0,0.8); backdrop-filter: blur(8px);"
      role="dialog"
      aria-modal="true"
      aria-label={svc.title}
    >
      <div class="relative bg-white w-full max-w-xl" style="border-radius: 2px; max-height: 90vh; overflow-y: auto;">
        <!-- Close -->
        <button
          class="svc-modal-close absolute top-4 right-4 z-10 w-9 h-9 flex items-center justify-center hover:bg-gray-100 transition-colors duration-200"
          style="border: 1px solid #E8E6E0; background: #fff;"
          aria-label="Close"
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 1L13 13M13 1L1 13" stroke="#111" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>

        <!-- Header -->
        <div class="px-8 pt-8 pb-6" style="border-bottom: 1px solid #E8E6E0;">
          {svc.price && <span class="font-body text-[10px] tracking-[0.2em] uppercase text-muted block mb-1">{svc.price}</span>}
          <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-1">Service</p>
          <h2 class="font-display font-bold text-text" style="font-size: 1.3rem;">{svc.title}</h2>
        </div>

        <!-- Body -->
        <div class="px-8 py-7">
          <p class="font-body text-sm text-muted leading-relaxed mb-8">{svc.detail}</p>
          <p class="font-body text-[10px] tracking-[0.2em] uppercase text-muted mb-4">What's included</p>
          <ul class="space-y-3 mb-8">
            {svc.includes.map(item => (
              <li class="flex items-center gap-3 font-body text-sm text-muted">
                <span class="w-4 h-px bg-text flex-shrink-0" aria-hidden="true"></span>
                {item}
              </li>
            ))}
          </ul>
          <a
            href="/contact"
            class="w-full inline-flex items-center justify-center font-body text-sm font-semibold py-3.5 transition-colors duration-200"
            style="background: #111; color: #fff; letter-spacing: 0.02em;"
            onmouseover="this.style.background='#333'"
            onmouseout="this.style.background='#111'"
          >
            Get in touch &#8594;
          </a>
        </div>
      </div>
    </div>
  ))}

</Layout>

<script>
  // Teleport modals to body to escape any transform contexts
  document.querySelectorAll('.svc-modal').forEach(modal => {
    document.body.appendChild(modal);
  });

  function closeSvcModal(modal: Element) {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.documentElement.style.overflow = '';
  }

  document.querySelectorAll('.svc-modal').forEach(modal => {
    modal.querySelector('.svc-modal-close')?.addEventListener('click', () => closeSvcModal(modal));
    modal.addEventListener('click', (e) => { if (e.target === modal) closeSvcModal(modal); });
  });

  document.querySelectorAll('.svc-modal-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-service');
      if (!id) return;
      const modal = document.getElementById(`svc-modal-${id}`);
      if (!modal) return;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.documentElement.style.overflow = 'hidden';
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    document.querySelectorAll('.svc-modal:not(.hidden)').forEach(modal => closeSvcModal(modal));
  });

  // Sync layouts
  function syncLayouts() {
    const isDark = document.documentElement.classList.contains('dark');
    const light = document.querySelector('.light-layout') as HTMLElement | null;
    const dark  = document.querySelector('.dark-layout')  as HTMLElement | null;
    if (light) light.style.display = isDark ? 'none' : 'block';
    if (dark)  dark.style.display  = isDark ? 'block' : 'none';
  }
  syncLayouts();
  const obs = new MutationObserver(syncLayouts);
  obs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>

<style>
  .light-layout { display: block; }
  .dark-layout  { display: none; }

  /* DARK HERO */
  .dk-svc-hero { border-bottom: 1px solid #1A1A1A; padding: 6rem 3rem 5rem; }
  @media (max-width: 768px) { .dk-svc-hero { padding: 4rem 1.5rem 3rem; } }
  .dk-svc-hero-inner { max-width: 860px; display: flex; flex-direction: column; gap: 2rem; }
  .dk-svc-label { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 9px; letter-spacing: 0.3em; color: rgba(255,255,255,0.2); text-transform: uppercase; }
  .dk-svc-heading { font-family: 'Cormorant Garant', serif; font-style: italic; font-weight: 300; font-size: clamp(3.5rem, 9vw, 8rem); line-height: 1.0; color: #FFFFFF; }
  .dk-svc-h-muted { color: rgba(255,255,255,0.3); }
  .dk-svc-sub { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.8rem; color: rgba(255,255,255,0.28); line-height: 1.7; max-width: 400px; }

  /* DARK SERVICE ROWS */
  .dk-svc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; padding: 5rem 3rem; border-bottom: 1px solid #1A1A1A; align-items: start; }
  @media (max-width: 768px) { .dk-svc-row { grid-template-columns: 1fr; gap: 2.5rem; padding: 3.5rem 1.5rem; } }
  .dk-svc-row-title { font-family: 'Cormorant Garant', serif; font-style: italic; font-weight: 300; font-size: clamp(1.6rem, 3vw, 2.4rem); color: #FFFFFF; line-height: 1.2; margin-bottom: 1.25rem; }
  .dk-svc-row-body { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.82rem; line-height: 1.85; color: rgba(255,255,255,0.4); max-width: 480px; }
  .dk-svc-items-label { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.18); margin-bottom: 1.5rem; }
  .dk-svc-items { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem; }
  .dk-svc-items li { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.78rem; color: rgba(255,255,255,0.35); padding-left: 1.25rem; position: relative; }
  .dk-svc-items li::before { content: '—'; position: absolute; left: 0; color: rgba(255,255,255,0.15); }

  /* DARK CTA */
  .dk-svc-cta { background: #FFFFFF; padding: 8rem 3rem; }
  .dk-svc-cta-inner { max-width: 860px; margin: 0 auto; display: flex; flex-direction: column; align-items: flex-start; gap: 1.75rem; }
  .dk-svc-cta-label { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 9px; letter-spacing: 0.3em; color: rgba(5,5,5,0.28); text-transform: uppercase; }
  .dk-svc-cta-heading { font-family: 'Cormorant Garant', serif; font-style: italic; font-weight: 300; font-size: clamp(2.5rem, 8vw, 7.5rem); color: #050505; line-height: 1.0; }
  .dk-svc-cta-btn { display: inline-block; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: #FFFFFF; background: #050505; padding: 1rem 2.25rem; text-decoration: none; transition: background 0.2s; }
  .dk-svc-cta-btn:hover { background: #1A1A1A; }
</style>
