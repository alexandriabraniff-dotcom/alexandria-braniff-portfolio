---
// About page — dual layout: "selling flowers" (light) / "expensive perfume bottle" (dark)
import Layout from '../layouts/Layout.astro';
import AnimateIn from '../components/AnimateIn.astro';
---

<Layout
  title="About — Alexandria Braniff"
  description="Web developer based in Vancouver, BC. I work with business owners at every stage, handling their entire online presence so they can focus on growing their business."
>

  <!-- ============================================
       LIGHT LAYOUT
  ============================================ -->
  <div class="light-layout">

    <!-- HERO -->
    <section class="border-b border-surface2 overflow-hidden relative">
      <img src="/images/page-header-bg.jpg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover pointer-events-none" style="opacity: 0.35;" />
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-10 lg:py-14 relative z-10">
        <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-4">About</p>
        <h1 class="font-serif text-text leading-[0.95]" style="font-size: clamp(2rem, 4vw, 3.5rem); font-style: italic; font-weight: 300; animation: fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) both 0.1s;">
          The person<br />behind the work.
        </h1>
        <p class="font-body text-sm text-muted max-w-md mt-4" style="animation: fadeUp 0.7s ease-out both 0.3s;">
          Custom websites for you and your business.
        </p>
      </div>
    </section>

    <!-- CONTENT -->
    <section class="px-6 lg:px-12 py-24 lg:py-32 border-b border-surface2">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-[1fr_1fr] gap-16 lg:gap-24">

          <AnimateIn>
            <div class="space-y-12">
              <div>
                <p class="font-serif text-text mb-4" style="font-size: 1.25rem; line-height: 1.4; font-style: italic; font-weight: 300;">
                  I work with business owners at every stage, big or small, local or global.
                </p>
                <p class="font-body text-sm text-muted leading-relaxed" style="line-height: 1.9;">
                  Your online presence should be the last thing you worry about. I handle everything, from the design and development to the launch and ongoing care, so you can focus on what you are actually good at: running your business. Whether you are just starting out or you have been building for years and need something that finally reflects where you are, I am here to make it happen.
                </p>
              </div>
              <div>
                <p class="font-serif text-text mb-4" style="font-size: 1.25rem; line-height: 1.4; font-style: italic; font-weight: 300;">
                  Your dream is the brief.
                </p>
                <p class="font-body text-sm text-muted leading-relaxed" style="line-height: 1.9;">
                  Every project starts with understanding what you are building toward, not just what you need on a website today. I want to know where you see your business going, who your customers are, and what success actually looks like for you. From there I build something that works now and grows with you over time.
                </p>
              </div>
              <div class="flex items-center justify-center" style="height: 300px; background: #F5F4F0; border: 1px solid #E8E6E0;">
                <p class="font-body text-[11px] tracking-[0.2em] uppercase text-muted">Coming Soon</p>
              </div>
            </div>
          </AnimateIn>

          <AnimateIn delay={150}>
            <div class="space-y-12">
              <div class="relative overflow-hidden" style="height: 320px;">
                <img src="/images/vancouver.webp" alt="Vancouver, BC" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              </div>
              <div>
                <p class="font-serif text-text mb-4" style="font-size: 1.25rem; line-height: 1.4; font-style: italic; font-weight: 300;">
                  I take care of everything online.
                </p>
                <p class="font-body text-sm text-muted leading-relaxed" style="line-height: 1.9;">
                  Domain, hosting, email, design, development, SEO, branding. Your entire online presence in one place. No coordinating multiple freelancers, no wondering who is responsible for what. You have one person who knows your business, your brand, and your goals, and who handles it all from start to finish.
                </p>
              </div>
              <div>
                <p class="font-serif text-text mb-4" style="font-size: 1.25rem; line-height: 1.4; font-style: italic; font-weight: 300;">
                  No stress. No worry. Just results.
                </p>
                <p class="font-body text-sm text-muted leading-relaxed" style="line-height: 1.9;">
                  Working with me means plain language, fast turnarounds, and no surprises. You know what is happening at every step. You deal with me directly, not a project manager or account rep. And when things need attention, whether it is a quick update or something bigger, you have someone in your corner who already knows your site inside out.
                </p>
              </div>
            </div>
          </AnimateIn>

        </div>
      </div>
    </section>

    <!-- VALUES STRIP -->
    <section class="border-b border-surface2 px-6 lg:px-12 py-16">
      <div class="max-w-7xl mx-auto">
        <AnimateIn>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-0" style="border: 1px solid #E8E6E0;">
            <div class="px-8 py-10" style="border-right: 1px solid #E8E6E0;">
              <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-3">Every business</p>
              <p class="font-serif text-text leading-[1.2]" style="font-size: 1.15rem; font-style: italic; font-weight: 300;">Startups to established brands. If you want to grow online, that is where I come in.</p>
            </div>
            <div class="px-8 py-10" style="border-right: 1px solid #E8E6E0;">
              <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-3">Everything handled</p>
              <p class="font-serif text-text leading-[1.2]" style="font-size: 1.15rem; font-style: italic; font-weight: 300;">Design, development, branding, SEO, hosting. One person, one point of contact, zero handoffs.</p>
            </div>
            <div class="px-8 py-10">
              <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-3">Built for growth</p>
              <p class="font-serif text-text leading-[1.2]" style="font-size: 1.15rem; font-style: italic; font-weight: 300;">Every site is built to grow with your business, not to be replaced the moment things change.</p>
            </div>
          </div>
        </AnimateIn>
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 lg:px-12 py-24 lg:py-32">
      <div class="max-w-7xl mx-auto">
        <AnimateIn>
          <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8 py-12 border-t border-surface2">
            <div>
              <h2 class="font-serif text-text" style="font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1.2; font-style: italic; font-weight: 300;">
                Ready to grow your business online?
              </h2>
              <p class="font-body text-sm text-muted mt-2">Tell me about your business and what you want to build.</p>
            </div>
            <a href="/contact" class="inline-flex items-center gap-3 font-body text-sm bg-text px-8 py-4 hover:bg-muted transition-colors duration-200 flex-shrink-0" style="color: #F7F6F2; font-weight: 500;">
              Get in touch <span aria-hidden="true">&#8594;</span>
            </a>
          </div>
        </AnimateIn>
      </div>
    </section>

  </div><!-- end .light-layout -->


  <!-- ============================================
       DARK LAYOUT
  ============================================ -->
  <div class="dark-layout">

    <!-- DK HERO -->
    <section class="dk-ab-hero">
      <div class="dk-ab-hero-inner">
        <div class="dk-ab-label">About</div>
        <h1 class="dk-ab-name">ALEXANDRIA<br />BRANIFF</h1>
        <div class="dk-ab-tagline">
          Web Developer
          <span class="dk-ab-separator" aria-hidden="true">·</span>
          Vancouver, BC
          <span class="dk-ab-separator" aria-hidden="true">·</span>
          Worldwide
        </div>
        <div class="dk-ab-stats-row">
          <div class="dk-ab-stat">
            <span class="dk-ab-stat-num" data-count-dk="20" data-suffix-dk="+">0+</span>
            <span class="dk-ab-stat-label">Sites built</span>
          </div>
          <div class="dk-ab-stat">
            <span class="dk-ab-stat-num" data-count-dk="3" data-suffix-dk="">0</span>
            <span class="dk-ab-stat-label">Years building</span>
          </div>
          <div class="dk-ab-stat">
            <span class="dk-ab-stat-num" data-count-dk="100" data-suffix-dk="%">0%</span>
            <span class="dk-ab-stat-label">From scratch</span>
          </div>
        </div>
      </div>
      <div class="dk-ab-hero-img">
        <img src="/images/alexandria-braniff.jpg" alt="Alexandria Braniff" style="object-position: top;" />
      </div>
    </section>

    <!-- DK MANIFESTO -->
    <section class="dk-manifesto">
      <div class="dk-manifesto-item">
        <span class="dk-manifesto-num">01</span>
        <div class="dk-manifesto-body">
          <h2 class="dk-manifesto-title">Your dream,<br />realized.</h2>
          <p class="dk-manifesto-text">Every project starts with understanding what you want to build and where you want to go. The website comes after that. I take the time to understand your business, your customers, and your goals before a single decision is made.</p>
        </div>
      </div>
      <div class="dk-manifesto-item">
        <span class="dk-manifesto-num">02</span>
        <div class="dk-manifesto-body">
          <h2 class="dk-manifesto-title">Every business.<br />Every stage.</h2>
          <p class="dk-manifesto-text">Startups or established brands, local or global, one employee or one hundred. If you want to grow online and want someone reliable handling it, that is exactly what I do.</p>
        </div>
      </div>
      <div class="dk-manifesto-item">
        <span class="dk-manifesto-num">03</span>
        <div class="dk-manifesto-body">
          <h2 class="dk-manifesto-title">One person.<br />Everything handled.</h2>
          <p class="dk-manifesto-text">Design, development, branding, SEO, hosting, ongoing care. Your entire online presence looked after by one person who knows it all, with no stress, no handoffs, and no wondering who to call.</p>
        </div>
      </div>
    </section>

    <!-- DK STACK -->
    <section class="dk-stack">
      <div class="dk-stack-sheet">
        <div class="dk-stack-sheet-header">
          <span class="dk-stack-sheet-title">Technical profile</span>
        </div>
        <div class="dk-stack-entry">
          <span class="dk-stack-key">Frontend</span>
          <span class="dk-stack-val">Next.js · Astro · React · Tailwind CSS · TypeScript</span>
        </div>
        <div class="dk-stack-entry">
          <span class="dk-stack-key">Backend</span>
          <span class="dk-stack-val">Node.js · Vercel · GitHub · REST APIs · Formspree</span>
        </div>
        <div class="dk-stack-entry">
          <span class="dk-stack-key">Specialties</span>
          <span class="dk-stack-val">Custom websites · Brand identity · SEO · Ongoing care · Digital setup</span>
        </div>
        <div class="dk-stack-entry">
          <span class="dk-stack-key">Location</span>
          <span class="dk-stack-val">Vancouver, BC — working with businesses around the world</span>
        </div>
      </div>
      <div class="dk-stack-img">
        <img src="/images/vancouver.webp" alt="Vancouver, BC" />
      </div>
    </section>

    <!-- DK CTA -->
    <section class="dk-ab-cta">
      <div class="dk-ab-cta-inner">
        <span class="dk-ab-cta-label">Ready</span>
        <h2 class="dk-ab-cta-heading">
          Let's build<br />something.
        </h2>
        <a href="/contact" class="dk-ab-cta-btn">Start a project &#8594;</a>
      </div>
    </section>

  </div><!-- end .dark-layout -->

</Layout>

<script>
  // Sync layouts on theme toggle
  function syncLayouts() {
    const isDark = document.documentElement.classList.contains('dark');
    const light = document.querySelector('.light-layout') as HTMLElement | null;
    const dark  = document.querySelector('.dark-layout')  as HTMLElement | null;
    if (light) light.style.display = isDark ? 'none' : 'block';
    if (dark)  dark.style.display  = isDark ? 'block' : 'none';
  }
  syncLayouts();
  const layoutObserver = new MutationObserver(syncLayouts);
  layoutObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

  // Count-up animation — dark layout
  const countElsDk = document.querySelectorAll('[data-count-dk]');
  const countObserverDk = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt((el as HTMLElement).dataset.countDk || '0');
      const suffix = (el as HTMLElement).dataset.suffixDk || '';
      const duration = 1200;
      const startTime = performance.now();
      function tick(now: number) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.floor(eased * target) + suffix;
        if (progress < 1) requestAnimationFrame(tick);
        else el.textContent = target + suffix;
      }
      requestAnimationFrame(tick);
      countObserverDk.unobserve(el);
    });
  }, { threshold: 0.6 });
  countElsDk.forEach((el) => countObserverDk.observe(el));
</script>

<style>
  /* ── Light layout defaults ── */
  .light-layout { display: block; }
  .dark-layout  { display: none; }

  .placeholder-img {
    position: relative;
    overflow: hidden;
    background: #F2F1ED;
  }

  /* ════════════════════════════════════
     DARK LAYOUT
  ════════════════════════════════════ */

  /* HERO */
  .dk-ab-hero {
    display: grid;
    grid-template-columns: 1fr 340px;
    min-height: 90vh;
    border-bottom: 1px solid #1A1A1A;
    overflow: hidden;
  }
  @media (max-width: 900px) {
    .dk-ab-hero { grid-template-columns: 1fr; }
    .dk-ab-hero-img { display: none; }
  }
  .dk-ab-hero-inner {
    padding: 6rem 3rem 5rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 1.75rem;
    border-right: 1px solid #1A1A1A;
  }
  .dk-ab-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 9px;
    letter-spacing: 0.3em;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
  }
  .dk-ab-name {
    font-family: 'Syne', sans-serif;
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 800;
    color: #FFFFFF;
    line-height: 0.9;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }
  .dk-ab-tagline {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .dk-ab-separator { color: rgba(255,255,255,0.1); }
  .dk-ab-stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid #1A1A1A;
    margin-top: 1.5rem;
  }
  .dk-ab-stat {
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-right: 1px solid #1A1A1A;
  }
  .dk-ab-stat:last-child { border-right: none; }
  .dk-ab-stat-num {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 800;
    color: #FFFFFF;
    line-height: 1;
  }
  .dk-ab-stat-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.58rem;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
  }
  .dk-ab-hero-img {
    position: relative;
    overflow: hidden;
  }
  .dk-ab-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    filter: grayscale(15%);
    display: block;
  }

  /* MANIFESTO */
  .dk-manifesto { border-bottom: 1px solid #1A1A1A; }
  .dk-manifesto-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 3rem;
    padding: 7rem 3rem;
    border-bottom: 1px solid #1A1A1A;
    align-items: start;
  }
  .dk-manifesto-item:last-child { border-bottom: none; }
  @media (max-width: 700px) {
    .dk-manifesto-item { grid-template-columns: 1fr; gap: 1.5rem; padding: 4rem 2rem; }
  }
  .dk-manifesto-num {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 9px;
    letter-spacing: 0.25em;
    color: rgba(255,255,255,0.18);
    text-transform: uppercase;
    padding-top: 0.5rem;
  }
  .dk-manifesto-body { display: flex; flex-direction: column; gap: 2rem; }
  .dk-manifesto-title {
    font-family: 'Cormorant Garant', serif;
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: #FFFFFF;
    line-height: 1.1;
  }
  .dk-manifesto-text {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.85rem;
    line-height: 1.9;
    color: rgba(255,255,255,0.58);
    max-width: 560px;
  }

  /* STACK */
  .dk-stack {
    display: grid;
    grid-template-columns: 1fr 380px;
    border-bottom: 1px solid #1A1A1A;
    min-height: 420px;
  }
  @media (max-width: 900px) {
    .dk-stack { grid-template-columns: 1fr; }
    .dk-stack-img { display: none; }
  }
  .dk-stack-sheet { padding: 4rem 3rem; border-right: 1px solid #1A1A1A; }
  .dk-stack-sheet-header { padding-bottom: 2.5rem; margin-bottom: 0; border-bottom: 1px solid #1A1A1A; }
  .dk-stack-sheet-title {
    font-family: 'Cormorant Garant', serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.1rem;
    color: rgba(255,255,255,0.4);
  }
  .dk-stack-entry {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 2rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid #111;
    align-items: baseline;
  }
  .dk-stack-entry:last-child { border-bottom: none; }
  .dk-stack-key {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.2);
    text-transform: uppercase;
  }
  .dk-stack-val {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
  }
  .dk-stack-img { position: relative; overflow: hidden; }
  .dk-stack-img img { width: 100%; height: 100%; object-fit: cover; opacity: 0.3; display: block; }

  /* DK CTA */
  .dk-ab-cta { background: #FFFFFF; padding: 8rem 3rem; display: flex; align-items: center; justify-content: center; }
  .dk-ab-cta-inner { max-width: 800px; width: 100%; display: flex; flex-direction: column; align-items: flex-start; gap: 1.5rem; }
  .dk-ab-cta-label { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 9px; letter-spacing: 0.3em; color: rgba(5,5,5,0.28); text-transform: uppercase; }
  .dk-ab-cta-heading { font-family: 'Cormorant Garant', serif; font-style: italic; font-weight: 300; font-size: clamp(2.5rem, 7vw, 6.5rem); color: #050505; line-height: 1.0; }
  .dk-ab-cta-btn { display: inline-block; align-self: flex-start; margin-top: 1.5rem; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: #FFFFFF; background: #050505; padding: 1rem 2.25rem; text-decoration: none; transition: background 0.2s; }
  .dk-ab-cta-btn:hover { background: #1A1A1A; }
</style>
