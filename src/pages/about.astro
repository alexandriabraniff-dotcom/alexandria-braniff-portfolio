---
// About page — dual layout: "selling flowers" (light) / "expensive perfume bottle" (dark)
import Layout from '../layouts/Layout.astro';
import AnimateIn from '../components/AnimateIn.astro';
---

<Layout
  title="About — Alexandria Braniff"
  description="Web developer based in Vancouver, BC. I work with business owners at every stage, handling their entire online presence so they can focus on growing their business."
>

  <!-- ============================================
       LIGHT LAYOUT
  ============================================ -->
  <div class="light-layout">

    <!-- HERO -->
    <section class="border-b border-surface2 overflow-hidden relative">
      <img src="/images/page-header-bg.jpg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover pointer-events-none" style="opacity: 0.35;" />
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-10 lg:py-14 relative z-10">
        <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-4">About</p>
        <h1 class="font-serif text-text leading-[0.95]" style="font-size: clamp(2rem, 4vw, 3.5rem); font-style: italic; font-weight: 300;">
          The person<br />behind the work.
        </h1>
        <p class="font-body text-sm text-muted max-w-md mt-4">
          Custom websites for you and your business.
        </p>
      </div>
    </section>

    <!-- CONTENT -->
    <section class="px-6 lg:px-12 py-24 lg:py-32 border-b border-surface2">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-[1fr_1fr] gap-16 lg:gap-24">

          <AnimateIn>
            <div class="space-y-12">
              <div>
                <p class="font-serif text-text mb-4" style="font-size: 1.25rem; line-height: 1.4; font-style: italic; font-weight: 300;">
                  I work with business owners at every stage, big or small, local or global.
                </p>
                <p class="font-body text-sm text-muted leading-relaxed" style="line-height: 1.9;">
                  Your online presence should be the last thing you worry about. I handle everything, from the design and development to the launch and ongoing care, so you can focus on what you are actually good at: running your business. Whether you are just starting out or you have been building for years and need something that finally reflects where you are, I am here to make it happen.
                </p>
              </div>
              <div>
                <p class="font-serif text-text mb-4" style="font-size: 1.25rem; line-height: 1.4; font-style: italic; font-weight: 300;">
                  Your dream is the brief.
                </p>
                <p class="font-body text-sm text-muted leading-relaxed" style="line-height: 1.9;">
                  Every project starts with understanding what you are building toward, not just what you need on a website today. I want to know where you see your business going, who your customers are, and what success actually looks like for you. From there I build something that works now and grows with you over time.
                </p>
              </div>
              <div class="flex items-center justify-center" style="height: 300px; background: #F5F4F0; border: 1px solid #E8E6E0;">
                <p class="font-body text-[11px] tracking-[0.2em] uppercase text-muted">Coming Soon</p>
              </div>
            </div>
          </AnimateIn>

          <AnimateIn delay={150}>
            <div class="space-y-12">
              <div class="relative overflow-hidden" style="height: 320px;">
                <img src="/images/vancouver.webp" alt="Vancouver, BC" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              </div>
              <div>
                <p class="font-serif text-text mb-4" style="font-size: 1.25rem; line-height: 1.4; font-style: italic; font-weight: 300;">
                  I take care of everything online.
                </p>
                <p class="font-body text-sm text-muted leading-relaxed" style="line-height: 1.9;">
                  Domain, hosting, email, design, development, SEO, branding. Your entire online presence in one place. No coordinating multiple freelancers, no wondering who is responsible for what. You have one person who knows your business, your brand, and your goals, and who handles it all from start to finish.
                </p>
              </div>
              <div>
                <p class="font-serif text-text mb-4" style="font-size: 1.25rem; line-height: 1.4; font-style: italic; font-weight: 300;">
                  No stress. No worry. Just results.
                </p>
                <p class="font-body text-sm text-muted leading-relaxed" style="line-height: 1.9;">
                  Working with me means plain language, fast turnarounds, and no surprises. You know what is happening at every step. You deal with me directly, not a project manager or account rep. And when things need attention, whether it is a quick update or something bigger, you have someone in your corner who already knows your site inside out.
                </p>
              </div>
            </div>
          </AnimateIn>

        </div>
      </div>
    </section>

    <!-- VALUES STRIP -->
    <section class="border-b border-surface2 px-6 lg:px-12 py-16">
      <div class="max-w-7xl mx-auto">
        <AnimateIn>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-0" style="border: 1px solid #E8E6E0;">
            <div class="px-8 py-10" style="border-right: 1px solid #E8E6E0;">
              <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-3">Every business</p>
              <p class="font-serif text-text leading-[1.2]" style="font-size: 1.15rem; font-style: italic; font-weight: 300;">Startups to established brands. If you want to grow online, that is where I come in.</p>
            </div>
            <div class="px-8 py-10" style="border-right: 1px solid #E8E6E0;">
              <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-3">Everything handled</p>
              <p class="font-serif text-text leading-[1.2]" style="font-size: 1.15rem; font-style: italic; font-weight: 300;">Design, development, branding, SEO, hosting. One person, one point of contact, zero handoffs.</p>
            </div>
            <div class="px-8 py-10">
              <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-3">Built for growth</p>
              <p class="font-serif text-text leading-[1.2]" style="font-size: 1.15rem; font-style: italic; font-weight: 300;">Every site is built to grow with your business, not to be replaced the moment things change.</p>
            </div>
          </div>
        </AnimateIn>
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 lg:px-12 py-24 lg:py-32">
      <div class="max-w-7xl mx-auto">
        <AnimateIn>
          <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8 py-12 border-t border-surface2">
            <div>
              <h2 class="font-serif text-text" style="font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1.2; font-style: italic; font-weight: 300;">
                Ready to grow your business online?
              </h2>
              <p class="font-body text-sm text-muted mt-2">Tell me about your business and what you want to build.</p>
            </div>
            <a href="/contact" class="inline-flex items-center gap-3 font-body text-sm bg-text px-8 py-4 hover:bg-muted transition-colors duration-200 flex-shrink-0" style="color: #F7F6F2; font-weight: 500;">
              Get in touch <span aria-hidden="true">&#8594;</span>
            </a>
          </div>
        </AnimateIn>
      </div>
    </section>

  </div><!-- end .light-layout -->



</Layout>


<style>
  .placeholder-img {
    position: relative;
    overflow: hidden;
    background: #F2F1ED;
  }
</style>
