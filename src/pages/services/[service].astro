---
import Layout from '../../layouts/Layout.astro';
import { services } from '../../data/services.js';

export async function getStaticPaths() {
  return services.map(svc => ({ params: { service: svc.id } }));
}

const { service } = Astro.params;
const svc = services.find(s => s.id === service);
if (!svc) return Astro.redirect('/services');
---

<Layout
  title={`${svc.title} — Alexandria Braniff`}
  description={svc.blurb}
>

  <!-- HEADER -->
  <section class="border-b border-surface2 relative overflow-hidden">
    <img src="/images/page-header-bg.jpg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover pointer-events-none" style="opacity: 0.35;" />
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-10 lg:py-14 relative z-10">
      <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-4">
        <a href="/services" class="hover:text-text transition-colors duration-200">Services</a>
        <span class="mx-2 opacity-40">/</span>
        {svc.title}
      </p>
      {svc.price && (
        <span class="inline-block font-body text-[10px] tracking-[0.18em] uppercase px-3 py-1.5 mb-4" style="background: #111; color: #F7F6F2;">
          From {svc.price}
        </span>
      )}
      <h1 class="font-serif text-text leading-[0.95]" style="font-size: clamp(2rem, 4vw, 3.5rem); font-style: italic; font-weight: 300;">
        {svc.title}
      </h1>
      {svc.lede && (
        <p class="font-body text-sm text-muted max-w-xl mt-5" style="line-height: 1.9;">
          {svc.lede}
        </p>
      )}
    </div>
  </section>

  <!-- SERVICE NAV DROPDOWN -->
  <div class="border-b border-surface2 sticky top-0 z-30" style="background: #F7F6F2;">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-3 flex items-center gap-4">
      <span class="font-body text-[10px] tracking-[0.2em] uppercase text-muted">Browse Services</span>
      <div class="relative">
        <button
          id="svc-dropdown-btn"
          class="flex items-center gap-2 font-body text-xs font-semibold tracking-[0.06em] uppercase text-text px-4 py-2 transition-colors duration-200"
          style="border: 1px solid #D5D3CB; background: #fff;"
          aria-haspopup="true"
          aria-expanded="false"
        >
          <span>{svc.title}</span>
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div
          id="svc-dropdown-menu"
          class="absolute left-0 top-full mt-1 w-64 hidden flex-col z-50"
          style="background: #fff; border: 1px solid #E8E6E0; box-shadow: 0 8px 24px rgba(0,0,0,0.08);"
        >
          {services.map(s => (
            <a
              href={`/services/${s.id}`}
              class={`font-body text-xs font-medium tracking-[0.04em] uppercase px-5 py-3.5 transition-colors duration-150 border-b last:border-0 ${s.id === svc.id ? 'text-text bg-surface2' : 'text-muted hover:text-text hover:bg-surface2'}`}
              style="border-color: #F2F1ED;"
            >
              {s.title}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <script>
    const btn = document.getElementById('svc-dropdown-btn');
    const menu = document.getElementById('svc-dropdown-menu');
    btn?.addEventListener('click', () => {
      const open = menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden', !open);
      menu?.classList.toggle('flex', !!open);
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    document.addEventListener('click', (e) => {
      if (!btn?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
        menu?.classList.add('hidden');
        menu?.classList.remove('flex');
        btn?.setAttribute('aria-expanded', 'false');
      }
    });
  </script>

  <!-- STEPS — alternating image/text sections -->
  {svc.steps && svc.steps.map((step, i) => (
    <section class="border-b border-surface2 py-16 lg:py-24 px-6 lg:px-12">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

          <!-- IMAGE — left on even, right on odd -->
          <div class={i % 2 === 1 ? 'lg:order-2' : 'lg:order-1'}>
            <img
              src={step.image}
              alt={step.heading}
              class="w-full block"
              style="border: 1px solid #E8E6E0;"
              loading="lazy"
            />
          </div>

          <!-- TEXT — right on even, left on odd -->
          <div class={`flex flex-col gap-5 ${i % 2 === 1 ? 'lg:order-1' : 'lg:order-2'}`}>
            <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted">{step.label}</p>
            <h2 class="font-serif text-text leading-[1.1]" style="font-size: clamp(1.5rem, 2.8vw, 2.2rem); font-style: italic; font-weight: 300;">
              {step.heading}
            </h2>
            <p class="font-body text-sm text-muted max-w-prose" style="line-height: 1.9;">
              {step.body}
            </p>
          </div>

        </div>
      </div>
    </section>
  ))}


  <!-- CTA -->
  <section style="background: #EEECEA; border-top: 1px solid #D5D3CB;">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16 lg:py-20">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
        <div>
          <h2 class="font-serif text-text leading-[1.05]" style="font-size: clamp(1.6rem, 3vw, 2.4rem); font-style: italic; font-weight: 300;">
            {svc.cta?.heading ?? 'Ready to get started?'}
          </h2>
          <p class="font-body text-sm text-muted mt-2">{svc.cta?.sub ?? "Let's talk about your project."}</p>
        </div>
        <a href="/contact" class="inline-flex items-center gap-3 font-body text-sm bg-text px-8 py-4 hover:bg-muted transition-colors duration-200 flex-shrink-0" style="color: #F7F6F2; font-weight: 500;">
          {svc.cta?.btn ?? 'Get in touch'} <span aria-hidden="true">&#8594;</span>
        </a>
      </div>
    </div>
  </section>

</Layout>

