---
import Layout from '../../layouts/Layout.astro';
import { services } from '../../data/services.js';
---

<Layout
  title="Services — Alexandria Braniff"
  description="Web design, development, SEO, maintenance and brand work for small businesses. Built from scratch by Alexandria Braniff."
>

  <!-- ============================================
       LIGHT LAYOUT
  ============================================ -->
  <div class="light-layout">

    <!-- HEADER -->
    <section class="border-b border-surface2 relative overflow-hidden">
      <img src="/images/page-header-bg.jpg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover pointer-events-none" style="opacity: 0.35;" />
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-10 lg:py-14 relative z-10">
        <p class="font-body text-[10px] tracking-[0.25em] uppercase text-muted mb-4">Services</p>
        <h1 class="font-serif text-text leading-[0.95]" style="font-size: clamp(2rem, 4vw, 3.5rem); font-style: italic; font-weight: 300;">
          Services
        </h1>
        <p class="font-body text-sm text-muted max-w-xl mt-4">
          From a brand new custom website to the ongoing work that keeps it fast and found, here is everything I can do for your business. Have a look through the overview, then click into whatever you want to know more about.
        </p>
      </div>
    </section>

    <!-- SERVICE NAV DROPDOWN -->
    <div class="border-b border-surface2 sticky top-0 z-30" style="background: #F7F6F2;">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-3 flex items-center gap-4">
        <span class="font-body text-[10px] tracking-[0.2em] uppercase text-muted">Browse Services</span>
        <div class="relative">
          <button
            id="svc-dropdown-btn"
            class="flex items-center gap-2 font-body text-xs font-semibold tracking-[0.06em] uppercase text-text px-4 py-2 transition-colors duration-200"
            style="border: 1px solid #D5D3CB; background: #fff;"
            aria-haspopup="true"
            aria-expanded="false"
          >
            <span>All Services</span>
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div
            id="svc-dropdown-menu"
            class="absolute left-0 top-full mt-1 w-64 hidden flex-col z-50"
            style="background: #fff; border: 1px solid #E8E6E0; box-shadow: 0 8px 24px rgba(0,0,0,0.08);"
          >
            {services.map((svc) => (
              <a
                href={`/services/${svc.id}`}
                class="font-body text-xs font-medium tracking-[0.04em] uppercase px-5 py-3.5 text-muted hover:text-text hover:bg-surface2 transition-colors duration-150 border-b last:border-0"
                style="border-color: #F2F1ED;"
              >
                {svc.title}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <script>
      const btn = document.getElementById('svc-dropdown-btn');
      const menu = document.getElementById('svc-dropdown-menu');
      btn?.addEventListener('click', () => {
        const open = menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', !open);
        menu?.classList.toggle('flex', !!open);
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      document.addEventListener('click', (e) => {
        if (!btn?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
          menu?.classList.add('hidden');
          menu?.classList.remove('flex');
          btn?.setAttribute('aria-expanded', 'false');
        }
      });
    </script>

    <!-- SERVICE SECTIONS — audits first, then the rest -->
    {[
      services.find(s => s.id === 'audits'),
      ...services.filter(s => s.id !== 'audits'),
    ].map((svc, i) => (
      <section id={svc.id} class="border-b border-surface2 py-16 lg:py-24 px-6 lg:px-12">
        <div class="max-w-7xl mx-auto">
          <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

            <!-- IMAGE — left on even, right on odd -->
            <div class={i % 2 === 1 ? 'lg:order-2' : 'lg:order-1'}>
              <img
                src={svc.image}
                alt={svc.title}
                class="w-full block"
                style="border: 1px solid #E8E6E0;"
                loading="lazy"
              />
            </div>

            <!-- TEXT -->
            <div class={`flex flex-col gap-5 ${i % 2 === 1 ? 'lg:order-1' : 'lg:order-2'}`}>
              {svc.price && (
                <span class="inline-block font-body text-[10px] tracking-[0.18em] uppercase px-3 py-1.5 self-start" style="background: #111; color: #F7F6F2;">
                  From {svc.price}
                </span>
              )}
              <h2 class="font-serif text-text leading-[1.05]" style="font-size: clamp(1.6rem, 3vw, 2.5rem); font-style: italic; font-weight: 300;">
                {svc.title}
              </h2>
              <p class="font-body text-sm text-muted leading-relaxed max-w-prose" style="line-height: 1.9;">
                {svc.overview}
              </p>
              <div class="mt-2">
                <a
                  href={`/services/${svc.id}`}
                  class="font-body text-sm font-medium text-text underline underline-offset-4 hover:text-muted transition-colors duration-200"
                >
                  Learn More &rarr;
                </a>
              </div>
            </div>

          </div>
        </div>
      </section>
    ))}

    <!-- FOOTER CTA -->
    <section style="background: #EEECEA; border-top: 1px solid #D5D3CB;">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16 lg:py-20">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
          <div>
            <h2 class="font-serif text-text leading-[1.05]" style="font-size: clamp(1.6rem, 3vw, 2.4rem); font-style: italic; font-weight: 300;">
              Not sure where to start?
            </h2>
            <p class="font-body text-sm text-muted mt-2 max-w-md">A website audit is the easiest first step. I will tell you exactly where your site stands and what is worth doing, with no obligation.</p>
          </div>
          <a href="/services/audits" class="inline-flex items-center gap-3 font-body text-sm bg-text px-8 py-4 hover:bg-muted transition-colors duration-200 flex-shrink-0" style="color: #F7F6F2; font-weight: 500;">
            Get a website audit <span aria-hidden="true">&#8594;</span>
          </a>
        </div>
      </div>
    </section>

  </div><!-- end .light-layout -->



</Layout>

<script>
  // Nav scroll
  document.querySelectorAll<HTMLButtonElement>('.svc-nav-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      if (!targetId) return;
      const section = document.getElementById(targetId);
      if (!section) return;
      // Account for sticky nav height
      const nav = btn.closest('div')?.parentElement as HTMLElement | null;
      const offset = nav ? nav.getBoundingClientRect().height : 57;
      const top = section.getBoundingClientRect().top + window.scrollY - offset;
      window.scrollTo({ top, behavior: 'smooth' });
    });
  });

  // IntersectionObserver to update active nav button
  const navBtns = document.querySelectorAll<HTMLButtonElement>('.svc-nav-btn');

  function setActive(id: string) {
    navBtns.forEach(btn => {
      const isActive = btn.getAttribute('data-target') === id;
      btn.classList.toggle('border-text', isActive);
      btn.classList.toggle('text-text', isActive);
      btn.classList.toggle('active', isActive);
      btn.classList.toggle('border-transparent', !isActive);
      if (!isActive) btn.classList.add('text-muted');
      else btn.classList.remove('text-muted');
    });
  }

  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
        }
      });
    },
    {
      rootMargin: '-40% 0px -55% 0px',
      threshold: 0,
    }
  );

  sections.forEach(section => {
    if (document.querySelector(`.svc-nav-btn[data-target="${section.id}"]`)) {
      observer.observe(section);
    }
  });
</script>

